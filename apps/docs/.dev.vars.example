# Wrangler reads ./apps/docs/.dev.vars when running `wrangler dev` locally.
# Copy this to `.dev.vars` (gitignored) and fill in real values from
# `secret.md` / Cloudflare dashboard / each provider.

# Better Auth: used to sign sessions. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=

# Resend: transactional email. Get a domain-scoped API key from resend.com.
RESEND_API_KEY=

# HMAC for unsubscribe-link signing. Independent from BETTER_AUTH_SECRET so
# we can rotate them on different cadences. Generate with `openssl rand -hex 32`.
UNSUBSCRIBE_HMAC_SECRET=

# Public site origin used by Better Auth redirects.
# Set to http://localhost:4321 for local dev. Production sets this in
# wrangler.jsonc -> vars.
PUBLIC_SITE_URL=http://localhost:4321
