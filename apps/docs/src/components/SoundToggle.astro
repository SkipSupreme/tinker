---
// Sound mute toggle. Sits beside ThemeToggle in the nav and is the only
// UI surface for the mute API in lib/sound.ts. State persists to
// localStorage (tinker:sound-muted) and, with no explicit choice yet,
// follows prefers-reduced-motion per DESIGN.md §Sound rules. The icon
// swaps on a data-muted attribute set by the inline script after read,
// so it can't flash the wrong glyph before hydration.
---
<button
  id="sound-toggle"
  class="sound-toggle"
  type="button"
  aria-label="Mute sound"
  aria-pressed="false"
  title="Mute sound"
  data-muted="false"
>
  <svg class="icon icon-on" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
    <path d="M4 9v6h4l5 4V5L8 9H4z" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round">
      <path d="M16 8.5a5 5 0 0 1 0 7" />
      <path d="M18.5 6a9 9 0 0 1 0 12" />
    </g>
  </svg>
  <svg class="icon icon-off" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
    <path d="M4 9v6h4l5 4V5L8 9H4z" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="16" y1="9.5" x2="21" y2="14.5" />
      <line x1="21" y1="9.5" x2="16" y2="14.5" />
    </g>
  </svg>
</button>

<script>
  import { isMuted, toggleMuted } from '../lib/sound';

  const btn = document.getElementById('sound-toggle');
  if (btn) {
    const sync = (muted: boolean) => {
      btn.dataset.muted = muted ? 'true' : 'false';
      btn.setAttribute('aria-pressed', muted ? 'true' : 'false');
      const label = muted ? 'Unmute sound' : 'Mute sound';
      btn.setAttribute('aria-label', label);
      btn.setAttribute('title', label);
    };
    sync(isMuted());
    btn.addEventListener('click', () => sync(toggleMuted()));
  }
</script>

<style>
  .sound-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    position: relative;
    padding: 0;
    background: transparent;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    color: var(--site-fg);
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .sound-toggle:hover {
    background: var(--site-surface);
    border-color: var(--site-fg-muted);
  }
  /* Invisible hit-area extension: 36px visual, 44px touch target. */
  .sound-toggle::after {
    content: "";
    position: absolute;
    inset: -4px;
  }
  .icon { grid-area: 1 / 1; transition: opacity 120ms ease, transform 180ms ease; }
  .sound-toggle[data-muted="false"] .icon-on { opacity: 1; transform: scale(1); }
  .sound-toggle[data-muted="false"] .icon-off { opacity: 0; transform: scale(0.85); }
  .sound-toggle[data-muted="true"] .icon-on { opacity: 0; transform: scale(0.85); }
  .sound-toggle[data-muted="true"] .icon-off { opacity: 1; transform: scale(1); }
</style>
