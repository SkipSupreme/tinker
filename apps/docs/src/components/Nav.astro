---
import ThemeToggle from './ThemeToggle.astro';
import UserMenu from './auth/UserMenu.svelte';
import XpCounter from './nav/XpCounter.svelte';
import StreakFlame from './nav/StreakFlame.svelte';
import { createAuth } from '../server/auth';

let user: { name: string; email: string } | null = null;
try {
  const { env } = await import('cloudflare:workers');
  const e = env as unknown as Env;
  if (e?.DB) {
    const auth = createAuth(e);
    const session = await auth.api.getSession({ headers: Astro.request.headers });
    if (session) user = { name: session.user.name ?? '', email: session.user.email };
  }
} catch {
  user = null;
}
---

<header class="site-header">
  <div class="shell">
    <a href="/" class="brand" aria-label="Tinker home">
      <img src="/logo-mark.png" alt="" class="brand-mark" width="432" height="477" />
      <span class="wordmark">Tinker<em class="bang">!</em></span>
    </a>

    <div class="spacer"></div>

    <div class="counters">
      <XpCounter client:load initial={0} />
      <StreakFlame client:load streak={0} />
    </div>

    <div class="auth-slot" data-auth-state={user ? 'user' : 'anon'}>
      <a
        href="/me"
        class="user-link"
        aria-label="Your account"
        data-auth-show="user"
        data-user-link
      >
        <span class="user-dot" aria-hidden="true" data-user-initial>
          {user ? (user.name || user.email).slice(0, 1).toUpperCase() : ''}
        </span>
        <span class="user-name" data-user-name>
          {user ? user.name || user.email.split('@')[0] : ''}
        </span>
      </a>
      <span class="auth-links" data-auth-show="anon">
        <a href="/signin" class="auth-link">Sign in</a>
        <a href="/signup" class="auth-cta">Sign up</a>
      </span>
    </div>

    <ThemeToggle />
    <UserMenu client:load />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--site-bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    border-bottom: 1px solid var(--site-border);
  }
  .shell {
    max-width: var(--max-shell);
    margin: 0 auto;
    padding: 0.65rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--site-fg);
    text-decoration: none;
  }
  .brand-mark {
    /* `/logo-mark.png` is the apple, cropped from the full lockup —
       no wordmark, no subtitle, no padding. So the nav can render it
       as a plain image with object-fit:contain and the whole apple is
       visible at any size. Aspect: 432, 477 ≈ 0.89:1 (slight portrait). */
    width: 44px;
    height: 44px;
    object-fit: contain;
    object-position: center;
    flex-shrink: 0;
  }
  .wordmark {
    font-family: var(--font-wordmark);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .wordmark .bang {
    font-style: normal;
    color: var(--ink-red);
    margin-left: 0.05em;
  }
  .spacer { flex: 1; }

  .counters {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .auth-slot {
    display: inline-flex;
    align-items: center;
  }
  .auth-slot[data-auth-state="user"] [data-auth-show="anon"] { display: none; }
  .auth-slot[data-auth-state="anon"] [data-auth-show="user"] { display: none; }
  .auth-links {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .auth-link {
    color: var(--site-fg);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
  }
  .auth-link:hover {
    background: var(--site-surface);
  }
  .auth-cta {
    color: var(--cta-fg);
    background: var(--cta);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 650;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1.5px solid var(--cta);
  }
  .auth-cta:hover {
    background: var(--cta-hover);
    border-color: var(--cta-hover);
  }
  .user-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--site-fg);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.3rem 0.6rem 0.3rem 0.3rem;
    border-radius: 999px;
    border: 1.5px solid var(--site-border);
  }
  .user-link:hover {
    background: var(--site-surface);
  }
  .user-dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 999px;
    background: var(--ink-red);
    color: white;
    font-weight: 700;
    font-size: 0.78rem;
  }

  /* Mobile: collapse the nav to its essentials. The XP counter and streak
     flame read as broken when they're 0 anonymously, and "Sign in" + "Sign up"
     side-by-side eats the whole row. Keep brand + primary CTA + theme toggle. */
  @media (max-width: 640px) {
    .shell {
      gap: 0.4rem;
      padding: 0.5rem 0.85rem;
    }
    .counters { display: none; }
    .auth-link { display: none; }
    .user-name { display: none; }
    .wordmark { font-size: 1.05rem; }
    .brand-mark { width: 36px; height: 36px; }
    .auth-cta {
      font-size: 0.85rem;
      padding: 0.35rem 0.7rem;
    }
  }

  @media (max-width: 380px) {
    .wordmark { display: none; }
  }
</style>

<script>
  /**
   * Auth hydration. Prerendered pages bake `data-auth-state="anon"` at build
   * time, so a logged-in visitor would otherwise see "Sign in / Sign up".
   * We fetch the session and flip the slot if there's a user. Skipped when
   * the server already rendered "user" (dynamic pages got it right).
   *
   * XP + streak listeners moved to components/nav/{XpCounter,StreakFlame}.svelte —
   * those own live updates via tinker:xp / tinker:streak. Server-side initial
   * values default to 0 since Astro.locals doesn't carry session XP/streak yet;
   * server hydration of those values lands when the auth schema grows xp + streak
   * columns (see plan).
   */
  type SessionResponse = { user?: { name?: string; email: string } };
  const slot = document.querySelector<HTMLElement>('.auth-slot');
  if (slot && slot.dataset.authState !== 'user') {
    fetch('/api/auth/get-session', { credentials: 'include' })
      .then((r) => (r.ok ? r.json() as Promise<SessionResponse> : null))
      .then((data) => {
        const user = data?.user;
        if (!user) return;
        const display = user.name || user.email.split('@')[0];
        const initial = (user.name || user.email).slice(0, 1).toUpperCase();
        slot.querySelector<HTMLElement>('[data-user-initial]')!.textContent = initial;
        slot.querySelector<HTMLElement>('[data-user-name]')!.textContent = display;
        slot.dataset.authState = 'user';
      })
      .catch(() => {
        /* network failure: leave anon state */
      });
  }
</script>
