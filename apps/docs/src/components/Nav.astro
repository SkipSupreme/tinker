---
import ThemeToggle from './ThemeToggle.astro';
import SoundToggle from './SoundToggle.astro';
import UserMenu from './auth/UserMenu.svelte';
import { createAuth } from '../server/auth';

let user: { name: string; email: string } | null = null;
try {
  const { env } = await import('cloudflare:workers');
  const e = env as unknown as Env;
  if (e?.DB) {
    const auth = createAuth(e);
    const session = await auth.api.getSession({ headers: Astro.request.headers });
    if (session) user = { name: session.user.name ?? '', email: session.user.email };
  }
} catch (e) {
  // Catch swallows everything (incl. BETTER_AUTH_SECRET missing, DB
  // binding missing, schema drift). Silent demotion to anon-header on a
  // misconfigured deploy is hard to diagnose; log so it's visible in
  // Cloudflare's tail logs.
  console.error('[nav] session lookup failed:', e);
  user = null;
}
---

<header class="site-header">
  <div class="shell">
    <a href="/" class="brand" aria-label="Tinker home">
      <img src="/logo-mark.png" alt="" class="brand-mark" width="432" height="477" />
      <span class="wordmark">Tinker<em class="bang">!</em></span>
    </a>

    <div class="spacer"></div>

    <a href="/lessons" class="nav-link">Course</a>

    {/* Anon-only: the "Sign in" pill. The signed-in avatar + dropdown is the
        <UserMenu> island below — having a user-link avatar here too produced
        two avatars side by side. data-auth-state flips to "user" for a
        signed-in visitor (CSS hides the pill), leaving UserMenu's avatar as
        the single account control. */}
    <div class="auth-slot" data-auth-state={user ? 'user' : 'anon'}>
      <span class="auth-links" data-auth-show="anon">
        <a href="/auth?mode=signin" class="auth-cta">Sign in</a>
      </span>
    </div>

    <SoundToggle />
    <ThemeToggle />
    <UserMenu client:load />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    /* The frosted-glass background + blur live on ::before (an absolutely-
       positioned child), NOT here. Safari 26 derives the browser toolbar tint
       from the topmost fixed/sticky element's background-color, and a
       translucent one (which the glass needs) produces an unpredictable, often
       light toolbar in dark mode. Leaving THIS sticky element transparent with
       no backdrop-filter gives Safari nothing to sample, so it falls back to
       the <body> background (var(--site-bg)) and the chrome follows the theme.
       Safari's tint sampler ignores absolute children, so the glass on ::before
       stays invisible to it while users still see it. */
    background: transparent;
    border-bottom: 1px solid var(--site-border);
  }
  .site-header::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--site-bg) 92%, transparent);
    /* -webkit- prefix is required for the blur to render in Safari at all. */
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    backdrop-filter: saturate(180%) blur(8px);
  }
  .shell {
    max-width: var(--max-shell);
    margin: 0 auto;
    padding: 0.65rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--site-fg);
    text-decoration: none;
  }
  .brand-mark {
    /* `/logo-mark.png` is the apple, cropped from the full lockup:
       no wordmark, no subtitle, no padding. So the nav can render it
       as a plain image with object-fit:contain and the whole apple is
       visible at any size. Aspect: 432, 477 ≈ 0.89:1 (slight portrait). */
    width: 44px;
    height: 44px;
    object-fit: contain;
    object-position: center;
    flex-shrink: 0;
  }
  .wordmark {
    font-family: var(--font-wordmark);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .wordmark .bang {
    font-style: normal;
    color: var(--ink-red);
    margin-left: 0.05em;
  }
  .spacer { flex: 1; }

  .auth-slot {
    display: inline-flex;
    align-items: center;
  }
  .auth-slot[data-auth-state="user"] [data-auth-show="anon"] { display: none; }
  .auth-slot[data-auth-state="anon"] [data-auth-show="user"] { display: none; }
  .auth-links {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  /* Course: quiet text link into the curriculum, present on every page so
     the marketing nav passes the trunk test (a way IN that isn't auth). */
  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 0.85rem;
    color: var(--site-fg);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1;
    border-radius: var(--radius-pill);
  }
  .nav-link:hover { background: var(--site-surface); }

  /* Sign in: outline pill. Deliberately NOT green — green is reserved for
     the page's single conversion CTA (DESIGN.md: one CTA color per page). */
  .auth-cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 1rem;
    color: var(--site-fg);
    background: transparent;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    border-radius: var(--radius-pill);
    border: 1.5px solid color-mix(in srgb, var(--site-fg) 25%, transparent);
  }
  .auth-cta:hover {
    background: var(--site-surface);
    border-color: color-mix(in srgb, var(--site-fg) 45%, transparent);
  }

  /* Mobile: collapse the nav to its essentials. "Sign in" + "Sign up"
     side-by-side eats the whole row. Keep brand + primary CTA + theme toggle. */
  @media (max-width: 640px) {
    .shell {
      gap: 0.4rem;
      padding: 0.5rem 0.85rem;
    }
    .wordmark { font-size: 1.05rem; }
    /* Mark shrinks to 36px visually; the link itself keeps a 44px target. */
    .brand { min-width: 44px; min-height: 44px; justify-content: flex-start; }
    .brand-mark { width: 36px; height: 36px; }
    .nav-link {
      font-size: 0.9rem;
      padding: 0 0.6rem;
    }
    .auth-cta {
      font-size: 0.9rem;
      padding: 0 0.8rem;
    }
  }

  @media (max-width: 380px) {
    .wordmark { display: none; }
  }
</style>

<script>
  /**
   * Auth hydration. Prerendered pages bake `data-auth-state="anon"` at build
   * time, so a logged-in visitor would otherwise see the "Sign in" pill. Flip
   * the slot to "user" (CSS hides the pill) when there's a session; the avatar
   * itself is rendered by the <UserMenu> island. Reuses the shared, memoized
   * session check so the whole page makes a single get-session request.
   */
  import { getSessionUser } from '../lib/auth-state';
  const slot = document.querySelector<HTMLElement>('.auth-slot');
  if (slot && slot.dataset.authState !== 'user') {
    getSessionUser().then((user) => {
      if (user) slot.dataset.authState = 'user';
    });
  }
</script>
