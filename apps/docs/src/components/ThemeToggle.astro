---
// A theme toggle button with three states (light / dark / system).
// Initial theme is set by the inline script in Base.astro before paint,
// so this button only needs to *flip* it — it never renders the wrong
// icon at the wrong moment because the script runs synchronously first.
---
<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  <svg class="icon icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
    <circle cx="12" cy="12" r="4" fill="currentColor" />
    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="2" x2="12" y2="5" />
      <line x1="12" y1="19" x2="12" y2="22" />
      <line x1="2" y1="12" x2="5" y2="12" />
      <line x1="19" y1="12" x2="22" y2="12" />
      <line x1="4.2" y1="4.2" x2="6.3" y2="6.3" />
      <line x1="17.7" y1="17.7" x2="19.8" y2="19.8" />
      <line x1="4.2" y1="19.8" x2="6.3" y2="17.7" />
      <line x1="17.7" y1="6.3" x2="19.8" y2="4.2" />
    </g>
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
    <path
      d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"
      fill="currentColor"
    />
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch {}
  });
</script>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    background: transparent;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    color: var(--site-fg);
    cursor: pointer;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .theme-toggle:hover {
    background: var(--site-surface);
    border-color: var(--site-fg-muted);
  }
  .icon { grid-area: 1 / 1; transition: opacity 120ms ease, transform 180ms ease; }
  :root[data-theme="dark"] .icon-sun { opacity: 1; transform: rotate(0); }
  :root[data-theme="dark"] .icon-moon { opacity: 0; transform: rotate(-30deg); }
  :root:not([data-theme="dark"]) .icon-sun { opacity: 0; transform: rotate(30deg); }
  :root:not([data-theme="dark"]) .icon-moon { opacity: 1; transform: rotate(0); }
</style>
