---
import Base from './Base.astro';
import TinkerHop from '../components/celebrate/TinkerHop.svelte';
import SrAnnouncer from '../components/lesson/SrAnnouncer.svelte';
import StuckHint from '../components/lesson/StuckHint.svelte';
import ProgressBeacon from '../components/lesson/ProgressBeacon.svelte';
import NotesDrawer from '../components/lesson/NotesDrawer.svelte';
import EndgameCallback from '../components/lesson/EndgameCallback.astro';
import PrevNext from '../components/lesson/PrevNext.astro';
import 'katex/dist/katex.min.css';

interface Sibling { title: string; href: string }
interface Props {
  slug: string;
  title: string;
  summary: string;
  estimatedMinutes: number;
  module: string;
  moduleHref?: string;
  moduleTitle?: string;
  prev?: Sibling | null;
  next?: Sibling | null;
  endgameBody?: string | null;
  /** True when this is the first lesson of its module — gates the
      "Previously" cross-module recap panel (Phase F). */
  moduleStart?: boolean;
  /** True when this is the last lesson of its module — gates the module-end
      "remember in 6 months" key-idea capture (Phase I) and the module-complete
      celebration. */
  moduleEnd?: boolean;
  /** Title of the next module in the course, shown in the module-complete
      celebration ("… unlocked"). Null on the course's final module. */
  nextModuleName?: string | null;
}
const {
  slug, title, summary, estimatedMinutes, module, moduleHref,
  moduleTitle: moduleTitleProp, prev = null, next = null, endgameBody = null,
  moduleStart = false, moduleEnd = false, nextModuleName = null,
} = Astro.props;
const moduleTitle = moduleTitleProp ?? module.replace(/-/g, ' ');
const moduleLabel = moduleTitle;
// Tinker currently ships a single course; every lesson lives under it. When
// additional courses launch, thread course slug through the lesson frontmatter
// and ['lessons']/[slug].astro alongside `module`.
const courseSlug = 'ml-math';
---

<Base title={title} description={summary} fullWidth>
  <div
    class="lesson-shell"
    data-lesson-slug={slug}
    data-module-slug={module}
    data-module-start={moduleStart ? 'true' : undefined}
    data-module-end={moduleEnd ? 'true' : undefined}
    data-next-module={nextModuleName ?? undefined}
  >
    <header class="lesson-header">
      <div class="shell">
        {moduleStart && (
          <aside class="recap-panel" data-recap-panel hidden>
            <p class="recap-eyebrow">Previously</p>
            <p class="recap-sub">A few things from earlier modules worth keeping warm.</p>
            <ul class="recap-cards" data-recap-cards></ul>
          </aside>
        )}
        <aside class="keyidea-mantra" data-keyidea-mantra hidden>
          <p class="keyidea-mantra-eyebrow">Your key idea</p>
          <p class="keyidea-mantra-text" data-keyidea-mantra-text></p>
        </aside>
        <p class="lesson-module">
          {moduleHref ? <a href={moduleHref}>{moduleLabel}</a> : moduleLabel}
          {' · '}{estimatedMinutes} min
        </p>
        <h1 class="lesson-title">{title}</h1>
        <p class="lesson-summary">{summary}</p>
        <div class="progress-track" role="progressbar"
             aria-label="Lesson progress"
             aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"
             data-progress-track>
          <div class="progress-fill" data-progress-fill></div>
          <span class="progress-label" data-progress-label>0 / 0</span>
        </div>
      </div>
    </header>

    <article class="lesson-body">
      <div class="shell">
        <slot />

        {endgameBody && <EndgameCallback body={endgameBody} moduleTitle={moduleTitle} />}

        <div class="lesson-complete" data-lesson-complete>
          <div class="lc-mascot">
            <TinkerHop client:idle level="lesson" size={120} />
          </div>
          <div class="lc-text">
            <p class="lc-eyebrow">Lesson complete</p>
            <h2 class="lc-headline">Nice tinkering.</h2>
          </div>
        </div>

        {moduleEnd && (
          <section class="keyidea-capture" data-keyidea-capture hidden>
            <p class="keyidea-eyebrow">Before you go</p>
            <h3 class="keyidea-q">In one sentence, what do you want to remember in 6 months?</h3>
            <textarea
              class="keyidea-input"
              data-keyidea-input
              rows="2"
              maxlength="500"
              placeholder="The one idea from this module worth keeping warm."
            ></textarea>
            <div class="keyidea-actions">
              <button type="button" class="keyidea-save" data-keyidea-save disabled>Save key idea</button>
              <span class="keyidea-flash" data-keyidea-flash aria-live="polite" hidden></span>
            </div>
          </section>
        )}

        {(prev || next) && moduleHref && (
          <PrevNext prev={prev} next={next} moduleHref={moduleHref} moduleTitle={moduleTitle} />
        )}
      </div>
    </article>

    <footer class="lesson-footer">
      <div class="shell">
        <button type="button" class="reset-btn" data-reset>Reset progress</button>
      </div>
    </footer>

    <SrAnnouncer client:idle />
    <StuckHint client:idle />
    <ProgressBeacon client:idle lessonSlug={slug} courseSlug={courseSlug} moduleSlug={module} />
    <NotesDrawer client:idle lessonSlug={slug} />
  </div>
</Base>

<style>
  .lesson-shell {
    /* Lesson chrome follows the global theme toggle. Colors resolve from
       :root (light) or :root[data-theme="dark"] so a single user toggle
       themes prose, header, step dividers, and the inline widgets together. */
    --lesson-fg: var(--site-fg);
    --lesson-fg-muted: var(--site-fg-muted);
    --lesson-surface: var(--demo-card);
    --lesson-border: var(--site-border);
    --lesson-violet: var(--ink-red);
    --lesson-coral:  var(--ink-coral);
    --lesson-sea:    var(--ink-sea);
    color: var(--lesson-fg);
    background: var(--band-white);
  }

  .lesson-header {
    padding: clamp(2.5rem, 5vw, 4rem) 1.25rem 1.5rem;
    background: var(--band-cream);
    border-bottom: 1px solid var(--lesson-border);
  }
  .lesson-header .shell { max-width: 780px; margin: 0 auto; }
  .lesson-module {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--lesson-violet);
    margin: 0 0 0.75rem;
  }
  .lesson-module a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    transition: border-color 160ms ease;
  }
  .lesson-module a:hover {
    border-bottom-color: currentColor;
  }
  .lesson-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }
  .lesson-summary {
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--lesson-fg-muted);
    margin: 0 0 1.5rem;
    max-width: 60ch;
  }

  /* "Previously" recap (Phase F): a quiet cross-module retention nudge that
     mounts above the title on a module's first lesson, populated client-side
     from due FSRS cards in prior modules. Stays hidden until the fetch
     returns cards, so signed-out / nothing-due learners never see an empty
     shell. Intentionally calm — the lesson is the headline, not this. */
  .recap-panel {
    margin: 0 0 1.75rem;
    padding: 1.1rem 1.25rem 1.25rem;
    border: 1px solid var(--lesson-border);
    border-radius: var(--radius-lg);
    background: var(--lesson-surface);
  }
  .recap-eyebrow {
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--lesson-coral);
    margin: 0 0 0.2rem;
  }
  .recap-sub {
    font-size: 0.85rem;
    color: var(--lesson-fg-muted);
    margin: 0 0 1rem;
  }
  .recap-cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .recap-card {
    border: 1px solid var(--lesson-border);
    border-radius: var(--radius-md);
    background: var(--band-white);
    padding: 0.9rem 1rem;
  }
  .recap-prompt {
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .recap-prompt :global(p:first-child) { margin-top: 0; }
  .recap-prompt :global(p:last-child) { margin-bottom: 0; }
  .recap-answer {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed color-mix(in srgb, var(--lesson-fg) 14%, transparent);
    font-size: 0.95rem;
  }
  .recap-answer-label { color: var(--lesson-fg-muted); margin-right: 0.4rem; }
  .recap-answer-value {
    font-family: var(--font-game);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  .recap-options { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.3rem; }
  .recap-option :global(p) { margin: 0; }
  .recap-actions {
    margin-top: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .recap-reveal {
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--lesson-border);
    background: transparent;
    color: var(--lesson-fg-muted);
    font-family: var(--font-game);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 140ms ease, color 140ms ease;
  }
  .recap-reveal:hover {
    color: var(--lesson-fg);
    border-color: color-mix(in srgb, var(--lesson-fg) 35%, transparent);
  }
  .recap-review {
    margin-left: auto;
    font-family: var(--font-game);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--lesson-fg-muted);
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .recap-review:hover {
    color: var(--cta);
    border-bottom-color: var(--cta);
  }
  @media (prefers-reduced-motion: reduce) {
    .recap-reveal, .recap-review { transition: none; }
  }

  .progress-track {
    position: relative;
    height: 6px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--lesson-fg) 8%, transparent);
    overflow: hidden;
  }
  .progress-fill {
    position: absolute;
    inset: 0 100% 0 0;
    background: var(--cta);
    transition: right 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .progress-label {
    position: absolute;
    right: 0;
    top: 10px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--lesson-fg-muted);
  }

  .lesson-body {
    padding: clamp(1rem, 3vw, 2.5rem) 1.25rem 3rem;
  }
  .lesson-body .shell { max-width: 780px; margin: 0 auto; }

  .lesson-footer {
    padding: 2rem 1.25rem 3rem;
    border-top: 1px solid var(--lesson-border);
  }
  .lesson-footer .shell {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    justify-content: flex-end;
  }
  .reset-btn {
    background: none;
    border: 1px solid var(--lesson-border);
    color: var(--lesson-fg-muted);
    padding: 0.5rem 0.9rem;
    border-radius: var(--radius-md);
    font: inherit;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .reset-btn:hover { background: var(--lesson-surface); color: var(--lesson-fg); }

  /* --- Step content styling --- */
  :global(.lesson-shell .step) {
    position: relative;
    padding: 1.75rem 0 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--lesson-fg) 8%, transparent);
    transition: opacity 360ms ease;
  }
  :global(.lesson-shell .step:last-of-type) { border-bottom: 0; }
  :global(.lesson-shell .step-title) {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
    line-height: 1.2;
    text-wrap: balance;
  }
  :global(.lesson-shell .step-body) {
    font-size: 1.08rem;
    line-height: 1.65;
  }
  :global(.lesson-shell .step-body p) { margin: 0 0 1.1rem; }
  :global(.lesson-shell .step-body p:last-child) { margin-bottom: 0; }
  :global(.lesson-shell .step-body em) { font-style: italic; }
  :global(.lesson-shell .step-body strong) { font-weight: 650; }
  :global(.lesson-shell .step-body .katex-display) { margin: 1.5rem 0; }

  /* Locked / unlocked states. `.step--locked` hides the content below the
     advance gate; the step itself remains in flow so the progress bar is
     accurate. */
  :global(.lesson-shell .step--locked) {
    opacity: 0.2;
    pointer-events: none;
    filter: blur(3px);
    user-select: none;
    max-height: 4rem;
    overflow: hidden;
  }
  :global(.lesson-shell .step--locked .step-advance),
  :global(.lesson-shell .step--locked .check-form) { display: none; }

  :global(.lesson-shell .step--completed .step-advance),
  :global(.lesson-shell .step--completed .check-form) { display: none; }

  :global(.lesson-shell .step-advance) {
    margin-top: 1.5rem;
  }
  :global(.lesson-shell .continue-btn) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.7rem 1.15rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--cta);
    background: var(--cta);
    color: var(--cta-fg);
    font: inherit;
    font-weight: 650;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background-color 140ms ease, transform 140ms ease;
  }
  :global(.lesson-shell .continue-btn:hover) {
    background: var(--cta-hover);
    border-color: var(--cta-hover);
    transform: translateY(-1px);
  }
  :global(.lesson-shell .continue-btn:disabled) {
    background: color-mix(in srgb, var(--lesson-fg) 10%, transparent);
    border-color: transparent;
    color: var(--lesson-fg-muted);
    cursor: not-allowed;
    transform: none;
  }

  /* StepCheck form. */
  :global(.lesson-shell .check-form) {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  :global(.lesson-shell .check-label) {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }
  :global(.lesson-shell .check-prompt) { color: var(--lesson-fg-muted); }
  :global(.lesson-shell .check-input) {
    padding: 0.65rem 0.85rem;
    border: 1.5px solid var(--lesson-border);
    border-radius: var(--radius-md);
    background: var(--lesson-surface);
    font: inherit;
    font-family: var(--font-mono);
    font-size: 1rem;
    width: 7.5rem;
  }
  :global(.lesson-shell .check-input:focus) {
    outline: none;
    border-color: var(--cta);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--cta) 22%, transparent);
  }
  :global(.lesson-shell .check-feedback) {
    width: 100%;
    margin: 0;
    font-size: 0.92rem;
    min-height: 1.2em;
  }
  :global(.lesson-shell .check-feedback.ok)    { color: var(--cta-hover); }
  :global(.lesson-shell .check-feedback.bad)   { color: var(--ink-coral); }
  :global(.lesson-shell .check-hint) {
    width: 100%;
    margin: 0;
    padding: 0.6rem 0.85rem;
    background: color-mix(in srgb, var(--ink-sun) 20%, transparent);
    border-left: 3px solid var(--ink-sun);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: 0.92rem;
    color: var(--lesson-fg);
  }

  /* StepChoice. Multiple-choice / select-all answer gate. The clickable
     options are slotted into .step-body; the Check button + feedback live
     in .choice-block so the lock/complete rules hide them like a
     StepCheck form, leaving the chosen options visible after completion. */
  :global(.lesson-shell .step--locked .choice-block),
  :global(.lesson-shell .step--completed .choice-block) { display: none; }

  :global(.lesson-shell .choice-option) {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    margin: 0.5rem 0;
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--lesson-border);
    border-radius: var(--radius-md);
    background: var(--lesson-surface);
    color: var(--lesson-fg);
    font: inherit;
    font-size: 1.02rem;
    text-align: left;
    cursor: pointer;
    transition: border-color 140ms ease, background-color 140ms ease,
      transform 140ms ease;
  }
  :global(.lesson-shell .choice-option:hover:not(:disabled)) {
    border-color: color-mix(in srgb, var(--cta) 55%, var(--lesson-border));
    transform: translateY(-1px);
  }
  :global(.lesson-shell .choice-option[aria-pressed='true']) {
    border-color: var(--cta);
    background: color-mix(in srgb, var(--cta) 12%, var(--lesson-surface));
  }
  :global(.lesson-shell .choice-option:disabled) { cursor: default; }
  :global(.lesson-shell .choice-option--right),
  :global(.lesson-shell .choice-option--right[aria-pressed='true']) {
    border-color: var(--cta-hover);
    background: color-mix(in srgb, var(--cta) 16%, var(--lesson-surface));
  }
  :global(.lesson-shell .choice-option--wrong[aria-pressed='true']) {
    border-color: var(--ink-coral);
    background: color-mix(in srgb, var(--ink-coral) 12%, var(--lesson-surface));
  }

  /* The marker box: an empty square that fills with a check when picked. */
  :global(.lesson-shell .choice-mark) {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border: 1.5px solid var(--lesson-border);
    border-radius: var(--radius-sm);
    background: transparent;
    position: relative;
    transition: border-color 140ms ease, background-color 140ms ease;
  }
  :global(.lesson-shell .choice-option[aria-pressed='true'] .choice-mark) {
    border-color: var(--cta);
    background: var(--cta);
  }
  :global(.lesson-shell .choice-option[aria-pressed='true'] .choice-mark)::after {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 0.16rem;
    width: 0.28rem;
    height: 0.58rem;
    border: solid var(--cta-fg);
    border-width: 0 2.5px 2.5px 0;
    transform: rotate(45deg);
  }
  :global(.lesson-shell .choice-option--wrong[aria-pressed='true'] .choice-mark) {
    border-color: var(--ink-coral);
    background: var(--ink-coral);
  }

  :global(.lesson-shell .choice-block) {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }
  :global(.lesson-shell .choice-feedback) {
    width: 100%;
    margin: 0;
    font-size: 0.92rem;
    min-height: 1.2em;
  }
  :global(.lesson-shell .choice-feedback.ok)  { color: var(--cta-hover); }
  :global(.lesson-shell .choice-feedback.bad) { color: var(--ink-coral); }

  /* Confidence-rating row (Phase H). Shown after a correct answer in lesson
     context to seed the FSRS card. Resting state is a quiet row of outlined
     chips; each tints toward an existing accent token on hover/focus only, so
     the default read stays calm rather than carnival. Lives inside the
     check-form / choice-block, so the .step--completed display:none rule
     disposes of it once the step advances. */
  :global(.lesson-shell .rating-row) {
    width: 100%;
    margin-top: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    animation: rating-row-in 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  @keyframes rating-row-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.lesson-shell .rating-row) { animation: none; }
  }
  :global(.lesson-shell .rating-prompt) {
    font-size: 0.85rem;
    color: var(--lesson-fg-muted);
    margin: 0 0.35rem 0 0;
  }
  :global(.lesson-shell .rating-btn) {
    padding: 0.4rem 0.85rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--lesson-border);
    background: var(--lesson-surface);
    color: var(--lesson-fg-muted);
    font: inherit;
    font-family: var(--font-game);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 140ms ease, color 140ms ease,
      background-color 140ms ease, transform 140ms ease;
  }
  :global(.lesson-shell .rating-btn:hover),
  :global(.lesson-shell .rating-btn:focus-visible) {
    color: var(--lesson-fg);
    transform: translateY(-1px);
    outline: none;
  }
  :global(.lesson-shell .rating-btn[data-rating='again']:hover),
  :global(.lesson-shell .rating-btn[data-rating='again']:focus-visible) {
    border-color: var(--ink-coral);
    background: color-mix(in srgb, var(--ink-coral) 12%, var(--lesson-surface));
  }
  :global(.lesson-shell .rating-btn[data-rating='hard']:hover),
  :global(.lesson-shell .rating-btn[data-rating='hard']:focus-visible) {
    border-color: var(--ink-sun);
    background: color-mix(in srgb, var(--ink-sun) 16%, var(--lesson-surface));
  }
  :global(.lesson-shell .rating-btn[data-rating='good']:hover),
  :global(.lesson-shell .rating-btn[data-rating='good']:focus-visible) {
    border-color: var(--cta);
    background: color-mix(in srgb, var(--cta) 12%, var(--lesson-surface));
  }
  :global(.lesson-shell .rating-btn[data-rating='easy']:hover),
  :global(.lesson-shell .rating-btn[data-rating='easy']:focus-visible) {
    border-color: var(--ink-sea);
    background: color-mix(in srgb, var(--ink-sea) 12%, var(--lesson-surface));
  }
  :global(.lesson-shell .rating-btn:focus-visible) {
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--cta) 22%, transparent);
  }

  /* Done state for the last step. */
  :global(.lesson-shell .step.is-final .step-advance) { display: none; }

  /* Final celebration after the last gate. Hidden until the script
     reveals it on lesson complete; reveal also dispatches
     `tinker:celebrate` so the embedded TinkerHop plays. */
  :global(.lesson-shell .lesson-complete) {
    display: none;
    margin-top: 2.5rem;
    padding: 1.75rem 1.5rem;
    border-radius: var(--radius-lg);
    background: var(--band-mint);
    border: 1px solid color-mix(in srgb, var(--cta-hover) 35%, transparent);
    align-items: center;
    gap: 1.25rem;
