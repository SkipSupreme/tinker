    overflow: hidden;
  }
  :global(.lesson-shell .lesson-complete.is-visible) {
    display: flex;
    animation: lesson-complete-in 520ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  @keyframes lesson-complete-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  :global(.lesson-shell .lesson-complete .lc-mascot) {
    flex-shrink: 0;
  }
  :global(.lesson-shell .lesson-complete .lc-text) {
    min-width: 0;
  }
  :global(.lesson-shell .lesson-complete .lc-eyebrow) {
    font-family: var(--font-game);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.75rem;
    color: var(--cta-hover);
    margin: 0 0 0.4rem;
  }
  :global(.lesson-shell .lesson-complete .lc-headline) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    margin: 0 0 0.3rem;
    line-height: 1.15;
    letter-spacing: -0.015em;
  }
  /* Green sweep overlay that pulses across on completion. */
  :global(.lesson-shell .lesson-complete.is-visible)::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--cta) 35%, transparent) 50%,
      transparent 100%
    );
    animation: green-sweep 720ms cubic-bezier(0.2, 0.8, 0.2, 1) 80ms 1;
    pointer-events: none;
  }
  @keyframes green-sweep {
    from { transform: translateX(-100%); }
    to   { transform: translateX(100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.lesson-shell .lesson-complete.is-visible) { animation: none; }
    :global(.lesson-shell .lesson-complete.is-visible)::before { display: none; }
  }

  /* Key idea (Phase I). The mantra banner persists the learner's saved
     one-sentence takeaway at the top of every lesson in the module; the
     capture card asks for it once, at the end of the final lesson. */
  .keyidea-mantra {
    margin: 0 0 1.75rem;
    padding: 0.95rem 1.15rem;
    border: 1px solid var(--lesson-border);
    border-left: 3px solid var(--lesson-coral);
    border-radius: var(--radius-md);
    background: var(--lesson-surface);
  }
  .keyidea-mantra-eyebrow {
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--lesson-coral);
    margin: 0 0 0.3rem;
  }
  .keyidea-mantra-text {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.45;
    margin: 0;
    color: var(--lesson-fg);
  }

  .keyidea-capture {
    margin-top: 2.5rem;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--lesson-border);
    border-radius: var(--radius-lg);
    background: var(--lesson-surface);
  }
  .keyidea-eyebrow {
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--lesson-coral);
    margin: 0 0 0.4rem;
  }
  .keyidea-q {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }
  .keyidea-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.75rem 0.9rem;
    border: 1.5px solid var(--lesson-border);
    border-radius: var(--radius-md);
    background: var(--band-white);
    color: var(--lesson-fg);
    font: inherit;
    font-size: 1rem;
    line-height: 1.5;
    resize: vertical;
    transition: border-color 140ms ease;
  }
  .keyidea-input:focus {
    outline: none;
    border-color: var(--cta);
  }
  .keyidea-actions {
    margin-top: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .keyidea-save {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-pill);
    border: 1.5px solid var(--cta);
    background: var(--cta);
    color: var(--cta-fg);
    font-family: var(--font-game);
    font-weight: 650;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background-color 140ms ease, transform 140ms ease;
  }
  .keyidea-save:hover:not(:disabled) {
    background: var(--cta-hover);
    border-color: var(--cta-hover);
    transform: translateY(-1px);
  }
  .keyidea-save:disabled {
    background: color-mix(in srgb, var(--lesson-fg) 10%, transparent);
    border-color: transparent;
    color: var(--lesson-fg-muted);
    cursor: not-allowed;
    transform: none;
  }
  .keyidea-flash {
    font-size: 0.85rem;
    color: var(--lesson-fg-muted);
  }
  @media (prefers-reduced-motion: reduce) {
    .keyidea-save { transition: none; }
  }
</style>

<script>
  import { play } from '../lib/sound';
  import { awardXp, XP_AWARD } from '../lib/xp';
  import { celebrateCorrect, celebrateLesson, celebrateModule, celebrateWrong } from '../lib/celebrate';
  import { TINKER_EVENT } from '../lib/events';
  import { lessonUnlockedKey, lessonCompletedKey } from '../lib/storage-keys';
  import { isAuthed } from '../lib/auth-state';

  type CheckData = { answer: number; tolerance: number };

  const FEEDBACK_OK = "Nice. That's right.";
  const FEEDBACK_FAR = "Not quite. Re-read the previous step and try again.";
  const FEEDBACK_CLOSE = "Close, check your precision.";

  const STUCK_MS = 30_000;

  type FsrsRating = 'again' | 'hard' | 'good' | 'easy';
  const RATING_PROMPT = 'How well did you know that?';
  const RATING_LABELS: ReadonlyArray<{ rating: FsrsRating; label: string }> = [
    { rating: 'again', label: 'Again' },
    { rating: 'hard', label: 'Hard' },
    { rating: 'good', label: 'Good' },
    { rating: 'easy', label: 'Easy' },
  ];
  // After a correct answer we surface the rating chips to seed the FSRS card
  // with a real confidence signal. If the learner doesn't pick within this
  // window we default to "good" and advance, so the lesson flow is never
  // blocked (Phase H of the retention layer).
  const RATING_DEFAULT_MS = 4_000;
  // Beat between picking a rating and advancing, so the tap registers visually.
  const RATING_ADVANCE_MS = 320;

  // Seed the FSRS card via /api/steps/answer. The lesson UI never blocks on
  // this POST (localStorage drives the local flow), but a transient server
  // failure used to silently drop the card from the spaced-repetition queue
  // forever — the learner is told it counted, yet the skill never enters
  // "N skills retained". So genuine failures are persisted to localStorage and
  // replayed on the next lesson load. 401/403 (anon) is expected and ignored.
  type FsrsSeedPayload = {
    step_id: string;
    lesson_slug: string;
    module_slug: string;
    answer: string;
    is_correct: boolean;
    rating: FsrsRating;
  };
  type PendingFsrsSeed = FsrsSeedPayload & {
    user_id: string;
    queued_at: number;
    attempts: number;
  };
  type SeedPostResult = 'ok' | 'auth' | 'retry' | 'rate-limit' | 'drop';
  type RetryUserResult =
    | { kind: 'user'; id: string }
    | { kind: 'anon' }
    | { kind: 'unknown' };

  const FSRS_RETRY_KEY = 'tinker:fsrs-seed-retry:v1';
  const FSRS_RETRY_CAP = 200;
  let retryUserPromise: Promise<RetryUserResult> | null = null;

  function isPendingSeed(value: unknown): value is PendingFsrsSeed {
    const v = value as Partial<PendingFsrsSeed> | null;
    return !!v &&
      typeof v.user_id === 'string' &&
      typeof v.step_id === 'string' &&
      typeof v.lesson_slug === 'string' &&
      typeof v.module_slug === 'string' &&
      typeof v.answer === 'string' &&
      typeof v.is_correct === 'boolean' &&
      (v.rating === 'again' || v.rating === 'hard' || v.rating === 'good' || v.rating === 'easy') &&
      typeof v.queued_at === 'number' &&
      Number.isFinite(v.queued_at) &&
      typeof v.attempts === 'number' &&
      Number.isFinite(v.attempts);
  }

  function seedKey(seed: PendingFsrsSeed): string {
    return `${seed.user_id}:${seed.step_id}`;
  }

  function seedEntryId(seed: PendingFsrsSeed): string {
    return `${seedKey(seed)}:${seed.queued_at}`;
  }

  function dedupePendingSeeds(seeds: PendingFsrsSeed[]): PendingFsrsSeed[] {
    const byKey = new Map<string, PendingFsrsSeed>();
    for (const seed of seeds) byKey.set(seedKey(seed), seed);
    return [...byKey.values()].slice(-FSRS_RETRY_CAP);
  }

  function loadPendingSeeds(): PendingFsrsSeed[] {
    try {
      const raw = localStorage.getItem(FSRS_RETRY_KEY);
      const arr = raw ? JSON.parse(raw) : [];
      return Array.isArray(arr) ? arr.filter(isPendingSeed) : [];
    } catch {
      return [];
    }
  }

  function savePendingSeeds(arr: PendingFsrsSeed[]): void {
    try {
      localStorage.setItem(FSRS_RETRY_KEY, JSON.stringify(dedupePendingSeeds(arr)));
    } catch {
      /* storage blocked; the seed is lost but the lesson UI is unaffected */
    }
  }

  function enqueuePendingSeed(payload: FsrsSeedPayload, userId: string): void {
    // Dedup per signed-in user + step_id: a fresh attempt supersedes any
    // earlier queued one, but entries never replay into another account.
    const entry: PendingFsrsSeed = {
      ...payload,
      user_id: userId,
      queued_at: Date.now(),
      attempts: 0,
    };
    savePendingSeeds([...loadPendingSeeds(), entry]);
  }

  async function getRetryUser(): Promise<RetryUserResult> {
    retryUserPromise ??= (async () => {
      try {
        const res = await fetch('/api/me/state?course=ml-math', {
          credentials: 'same-origin',
          headers: { accept: 'application/json' },
        });
        if (res.status === 401 || res.status === 403) return { kind: 'anon' };
        if (!res.ok) return { kind: 'unknown' };
        const body = await res.json() as { user?: { id?: unknown } };
        return typeof body.user?.id === 'string'
          ? { kind: 'user', id: body.user.id }
          : { kind: 'unknown' };
      } catch {
        return { kind: 'unknown' };
      }
    })();
    return retryUserPromise;
  }

  // Retry only transient failures. Permanent validation/not-found errors are
  // dropped; rate-limit responses stay queued for a later page load.
  async function postSeed(payload: FsrsSeedPayload): Promise<SeedPostResult> {
    try {
      const res = await fetch('/api/steps/answer', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
        keepalive: true,
      });
      if (res.ok) return 'ok';
      if (res.status === 401 || res.status === 403) return 'auth';
      if (res.status === 429) return 'rate-limit';
      if (res.status === 408 || res.status >= 500) {
        console.error('[lesson] steps/answer returned', res.status);
        return 'retry';
      }
      console.warn('[lesson] dropping unretryable steps/answer response', res.status);
      return 'drop';
    } catch (e) {
      console.warn('[lesson] steps/answer fetch failed', e);
      return 'retry';
    }
  }

  function bumpAttempt(seed: PendingFsrsSeed): PendingFsrsSeed {
    return { ...seed, attempts: seed.attempts + 1 };
  }

  // Replay seeds that failed on a prior load, but only for the same signed-in
  // user that queued them. Ownerless legacy entries are discarded by
  // loadPendingSeeds(); replaying them would risk cross-account attribution.
  async function flushPendingSeeds(): Promise<void> {
    const pending = loadPendingSeeds();
    if (pending.length === 0) {
      savePendingSeeds([]);
      return;
    }

    const user = await getRetryUser();
    if (user.kind !== 'user') return;

    const started = new Set(pending.map(seedEntryId));
    const stillPending: PendingFsrsSeed[] = [];
    let rateLimited = false;

    for (const p of pending) {
      if (p.user_id !== user.id || rateLimited) {
        stillPending.push(p);
        continue;
      }

      const result = await postSeed(p);
      if (result === 'retry' || result === 'auth') {
        stillPending.push(bumpAttempt(p));
      } else if (result === 'rate-limit') {
        stillPending.push(bumpAttempt(p));
        rateLimited = true;
      }
    }

    // Preserve entries enqueued while this flush was in flight.
    const latest = loadPendingSeeds();
    const additions = latest.filter((p) => !started.has(seedEntryId(p)));
    savePendingSeeds([...stillPending, ...additions]);
  }

  function seedFsrsCard(opts: {
    stepId: string;
    lessonSlug: string;
    moduleSlug: string;
    answer: string;
    rating: FsrsRating;
  }) {
    const payload: FsrsSeedPayload = {
      step_id: opts.stepId,
      lesson_slug: opts.lessonSlug,
      module_slug: opts.moduleSlug,
      answer: opts.answer,
      is_correct: true,
      rating: opts.rating,
    };
    // Skip the POST for logged-out visitors. It would 401 (expected, ignored
    // server-side), but the browser still surfaces a red "Failed to load
    // resource: 401" on every correct answer. Gating on the memoized session
    // check mirrors ProgressBeacon and lib/auth-state.ts; postSeed still maps
    // 401/403 to 'auth' as a safety net for a session that expired mid-lesson.
    void (async () => {
      if (!(await isAuthed())) return;
      const r = await postSeed(payload);
      if (r !== 'retry' && r !== 'rate-limit') return;
      const user = await getRetryUser();
      if (user.kind === 'user') enqueuePendingSeed(payload, user.id);
    })();
  }

  // Drain any previously-failed seeds once per lesson load (non-blocking).
  void flushPendingSeeds();

  // Mount the Again/Hard/Good/Easy chips inside `container`. Calls `onPick`
  // exactly once: on a chip click, or on the default-to-"good" timeout.
  // Returns a `cancel` that disarms the row WITHOUT picking — used on reset so
  // an orphaned timeout can't seed a card or advance after the user bailed.
  function mountRatingRow(
    container: HTMLElement,
    onPick: (rating: FsrsRating) => void,
  ): () => void {
    container.querySelector('.rating-row')?.remove();

    const row = document.createElement('div');
    row.className = 'rating-row';
    row.setAttribute('role', 'group');
    row.setAttribute('aria-label', RATING_PROMPT);

    const prompt = document.createElement('span');
    prompt.className = 'rating-prompt';
    prompt.textContent = RATING_PROMPT;
    row.appendChild(prompt);

    let resolved = false;
    let timer: number | null = null;
    const disarm = () => {
      resolved = true;
      if (timer !== null) {
        clearTimeout(timer);
        timer = null;
      }
    };
    const resolve = (rating: FsrsRating) => {
      if (resolved) return;
      disarm();
      onPick(rating);
    };

    for (const { rating, label } of RATING_LABELS) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rating-btn';
      btn.dataset.rating = rating;
      btn.textContent = label;
      btn.addEventListener('click', () => {
        play('tick');
        resolve(rating);
      });
      row.appendChild(btn);
    }

    container.appendChild(row);
    timer = window.setTimeout(() => resolve('good'), RATING_DEFAULT_MS);
    return disarm;
  }

  // "Previously" recap (Phase F). On a module's first lesson, pull the
  // learner's due cards from PRIOR modules and surface up to three as
  // click-to-reveal cues above the title. The prompt/answer HTML is resolved
  // server-side from the build-time manifest, so the response is already
  // render-ready and the heavy manifest never ships to the client.
  type RecapCard =
    | {
        stepId: string;
        promptHTML: string;
        answerType: 'check';
        answer: number | null;
        answerLabel: string;
      }
    | {
        stepId: string;
        promptHTML: string;
        answerType: 'choice';
        options: { html: string; correct: boolean }[];
      };

  function buildRecapCard(card: RecapCard): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'recap-card';

    const prompt = document.createElement('div');
    prompt.className = 'recap-prompt';
    // Trusted: promptHTML is generated at build time from our own lesson MDX.
    prompt.innerHTML = card.promptHTML;
    li.appendChild(prompt);

    const answer = document.createElement('div');
    answer.className = 'recap-answer';
    answer.hidden = true;
    if (card.answerType === 'check') {
      const label = document.createElement('span');
      label.className = 'recap-answer-label';
      label.textContent = card.answerLabel;
      const value = document.createElement('span');
      value.className = 'recap-answer-value';
      value.textContent = card.answer === null ? '—' : String(card.answer);
      answer.appendChild(label);
      answer.appendChild(value);
    } else {
      const ul = document.createElement('ul');
      ul.className = 'recap-options';
      // Recap shows the right answer, not the distractors.
      for (const opt of card.options) {
        if (!opt.correct) continue;
        const item = document.createElement('li');
        item.className = 'recap-option';
        item.innerHTML = opt.html;
        ul.appendChild(item);
      }
      answer.appendChild(ul);
    }
    li.appendChild(answer);

    const actions = document.createElement('div');
    actions.className = 'recap-actions';
    const reveal = document.createElement('button');
    reveal.type = 'button';
    reveal.className = 'recap-reveal';
    reveal.textContent = 'Reveal';
    reveal.addEventListener('click', () => {
      const showing = answer.hidden;
      answer.hidden = !showing;
      reveal.textContent = showing ? 'Hide' : 'Reveal';
      if (showing) play('tick');
    });
    const review = document.createElement('a');
    review.className = 'recap-review';
    review.href = '/review';
    review.textContent = 'Review →';
    actions.appendChild(reveal);
    actions.appendChild(review);
    li.appendChild(actions);

    return li;
  }

  async function mountRecap(root: HTMLElement) {
    if (root.dataset.moduleStart !== 'true') return;
    const panel = root.querySelector<HTMLElement>('[data-recap-panel]');
    const list = root.querySelector<HTMLElement>('[data-recap-cards]');
    if (!panel || !list) return;
    // Cross-module recap is account history; skip (and don't 401) for anon.
    if (!(await isAuthed())) return;
    const moduleSlug = root.dataset.moduleSlug ?? '';

    let res: Response;
    try {
      res = await fetch(`/api/modules/${encodeURIComponent(moduleSlug)}/recap`, {
        credentials: 'same-origin',
      });
    } catch {
      return; // offline / network error: the panel is optional, skip silently
    }
    // 401 (anon), 404 (unknown module), or any error: no panel.
    if (!res.ok) return;

    let cards: RecapCard[] = [];
    try {
      const data = (await res.json()) as { cards?: RecapCard[] };
      cards = data.cards ?? [];
    } catch {
      return;
    }
    if (cards.length === 0) return; // nothing due from prior modules

    for (const card of cards) list.appendChild(buildRecapCard(card));
    panel.hidden = false;
  }

  // Key idea (Phase I). Reveals the learner's saved one-sentence takeaway as a
  // mantra at the top of every lesson in the module, and — on the module's last
  // lesson only — wires the capture textarea so they can write or edit it.
  // No-ops gracefully for anon visitors (GET 401) and offline.
  async function mountKeyIdea(root: HTMLElement) {
    const moduleSlug = root.dataset.moduleSlug ?? '';
    if (!moduleSlug) return;
    // The "remember in 6 months" key idea is saved to the account; skip the
    // load/save wiring (and its guaranteed 401) for anonymous visitors.
    if (!(await isAuthed())) return;

    const mantra = root.querySelector<HTMLElement>('[data-keyidea-mantra]');
    const mantraText = root.querySelector<HTMLElement>('[data-keyidea-mantra-text]');
    const capture = root.querySelector<HTMLElement>('[data-keyidea-capture]');
    const input = root.querySelector<HTMLTextAreaElement>('[data-keyidea-input]');
    const saveBtn = root.querySelector<HTMLButtonElement>('[data-keyidea-save]');
    const flash = root.querySelector<HTMLElement>('[data-keyidea-flash]');

    // Last value confirmed by the server. Drives the mantra and the save
    // button's enabled state (an unchanged idea can't be re-submitted).
    let savedText = '';

    function showMantra(text: string) {
      if (!mantra || !mantraText) return;
      mantraText.textContent = text;
      mantra.hidden = text.length === 0;
    }

    function syncSaveState() {
      if (!saveBtn || !input) return;
      const text = input.value.trim();
      saveBtn.disabled = text.length === 0 || text === savedText;
    }

    function setFlash(msg: string) {
      if (!flash) return;
      flash.textContent = msg;
      flash.hidden = msg.length === 0;
    }

    // Wire the capture synchronously so the textarea is usable before the GET
    // round-trip resolves. render() owns the section's visibility (hidden until
    // the lesson is complete), so we never touch capture.hidden here.
    if (capture && input && saveBtn) {
      input.addEventListener('input', () => {
        setFlash('');
        syncSaveState();
      });
      saveBtn.addEventListener('click', () => {
        const text = input.value.trim();
        if (text.length === 0) return;
        saveBtn.disabled = true;
        setFlash('Saving…');
        fetch(`/api/modules/${encodeURIComponent(moduleSlug)}/key-idea`, {
          method: 'PUT',
          credentials: 'same-origin',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ text }),
        }).then((res) => {
          if (res.ok) {
            savedText = text;
            showMantra(text);
            setFlash('Saved.');
            play('tick');
          } else if (res.status === 401) {
            setFlash('Sign in to save your key idea.');
          } else {
            setFlash('Could not save — try again.');
          }
          syncSaveState();
        }).catch(() => {
          setFlash('Could not save — try again.');
          syncSaveState();
        });
      });
    }

    let res: Response;
    try {
      res = await fetch(`/api/modules/${encodeURIComponent(moduleSlug)}/key-idea`, {
        credentials: 'same-origin',
      });
    } catch {
      return; // offline: the mantra is optional, skip silently
    }
    if (!res.ok) return; // 401 (anon) / 404 (unknown module) / error: no mantra

    let text = '';
    try {
      const data = (await res.json()) as { text?: string };
      text = (data.text ?? '').trim();
    } catch {
      return;
    }
    if (text.length === 0) {
      syncSaveState();
      return;
    }
    savedText = text;
    showMantra(text);
    if (input) {
      input.value = text;
      syncSaveState();
    }
  }

  function initLesson(root: HTMLElement) {
    const slug = root.dataset.lessonSlug ?? 'unknown';
    const moduleSlug = root.dataset.moduleSlug ?? 'unknown';
    const storageKey = lessonUnlockedKey(slug);
    const completionKey = lessonCompletedKey(slug);

    // Fire-and-forget: the recap is a peripheral nudge and must never block
    // or delay lesson init. It no-ops unless this is a module-start lesson
    // with due prior-module cards for a signed-in learner.
    void mountRecap(root);
    // Same fire-and-forget contract: reveals the saved mantra and wires the
    // module-end capture textarea. No-ops for anon visitors and offline.
    void mountKeyIdea(root);

    const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-step]'));
    steps.forEach((step, i) => step.dataset.index = String(i));

    const total = steps.length;
    const fill = root.querySelector<HTMLElement>('[data-progress-fill]');
    const label = root.querySelector<HTMLElement>('[data-progress-label]');
    const track = root.querySelector<HTMLElement>('[data-progress-track]');
    const completeCard = root.querySelector<HTMLElement>('[data-lesson-complete]');
    // Present only on the module's last lesson (moduleEnd). Shares the
    // completeCard visibility gate so it appears with the completion card and
    // reappears on reload of an already-finished module-end lesson.
    const keyIdeaCapture = root.querySelector<HTMLElement>('[data-keyidea-capture]');

    // Guard storage reads: Safari Private Browsing / blocked site data throws
    // on access. An unguarded read here would abort initLesson() entirely
    // (steps never wired); an unguarded write in persist() would abort
    // advance() mid-flight and freeze the lesson. Degrade to in-memory progress.
    let saved = 0;
    let lessonCompleteFired = false;
    try {
      saved = Number.parseInt(localStorage.getItem(storageKey) ?? '0', 10);
      lessonCompleteFired = localStorage.getItem(completionKey) === '1';
    } catch {
      /* storage blocked; treat as a fresh, uncompleted lesson */
    }
    let unlocked = Number.isFinite(saved) ? Math.max(0, Math.min(saved, total)) : 0;
    // Disarms the currently-mounted confidence-rating row (if any) so its
    // default-to-"good" timeout can't fire after a reset or re-answer.
    let cancelActiveRating: (() => void) | null = null;

    function persist() {
      try {
        localStorage.setItem(storageKey, String(unlocked));
      } catch {
        // Storage blocked/quota: keep advancing in-memory rather than letting
        // the throw abort advance() and freeze the lesson on a correct answer.
      }
    }

    function render() {
      steps.forEach((step, i) => {
        step.classList.toggle('step--locked', i > unlocked);
        step.classList.toggle('step--completed', i < unlocked);
        step.classList.toggle('step--active', i === unlocked);
      });
      const pct = Math.round((unlocked / total) * 100);
      if (fill) fill.style.right = `${100 - pct}%`;
      if (label) label.textContent = `${unlocked} / ${total}`;
      if (track) track.setAttribute('aria-valuenow', String(pct));
      if (completeCard) {
        completeCard.classList.toggle('is-visible', unlocked >= total && total > 0);
      }
      if (keyIdeaCapture) {
        keyIdeaCapture.hidden = !(unlocked >= total && total > 0);
      }
    }

    function maybeFireLessonComplete() {
      if (lessonCompleteFired) return;
      if (unlocked < total || total === 0) return;
      lessonCompleteFired = true;
      try { localStorage.setItem(completionKey, '1'); } catch { /* ignore */ }
      // Persist completion server-side for signed-in users. Fire-and-forget:
      // localStorage already records local completion, so a network failure
      // or 401 (anon visitor) is silently ignored.
      fetch('/api/progress/complete', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'content-type': 'application/json',
        },
        body: JSON.stringify({ lesson_slug: slug }),
        keepalive: true,
      }).then((res) => {
        // 401/403/429 are expected (anon flow, same-origin guard, rate-limit);
        // anything else is a server-side bug we'd otherwise never hear about.
        if (!res.ok && res.status !== 401 && res.status !== 403 && res.status !== 429) {
          console.error('[lesson] progress/complete returned', res.status);
        }
      }).catch((e) => {
        console.warn('[lesson] progress/complete fetch failed', e);
      });
      // Route the entire endgame through the orchestrator: burst + XP tween +
      // TinkerHop event + chime/anthem + vibrate + aria-live announce. One
      // call, one tuned chain. Finishing the LAST lesson of a module fires the
      // bigger module-complete celebration (anthem + 28-confetti burst + 100
      // XP + "… unlocked") instead of the per-lesson one; it supersedes the
      // lesson celebration so sound/XP don't double up.
      if (completeCard) {
        if (root.dataset.moduleEnd === 'true') {
          // nodeId = module slug. celebrate.ts's SkillTreeMap glow hook
          // (glowMasteredNode) is still stubbed; passing the slug keeps the
          // call ready for when the map node lands.
          void celebrateModule(completeCard, moduleSlug, root.dataset.nextModule || undefined);
        } else {
          void celebrateLesson(completeCard);
        }
      } else {
        // No card in DOM (shouldn't happen); fall back to bare XP so the
        // user still gets credit for finishing the lesson.
        awardXp(XP_AWARD.lessonComplete, `lesson:${slug}`);
      }
      // Scroll to the celebration card so the user sees the moment.
      setTimeout(() => {
        completeCard?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 240);
    }

    function advance(fromIndex: number) {
      if (fromIndex !== unlocked) return;
      unlocked = Math.min(total, unlocked + 1);
      persist();
      render();
      // Step-advance award. The XP for "correct" is awarded separately by
      // the StepCheck handler before advance() runs, so this fires for
      // both regular continue clicks and post-check advance.
      awardXp(XP_AWARD.stepAdvance, `step:${slug}:${fromIndex}`);
      const nextStep = steps[unlocked];
      if (nextStep) {
        // Let the CSS transition settle a beat before scrolling so the
        // unlocked step is already rendered at full opacity.
        setTimeout(() => {
          nextStep.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 120);
      }
      armActiveStuckTimer();
      maybeFireLessonComplete();
    }

    // Wire "Continue" buttons in regular steps.
    steps.forEach((step) => {
      const cont = step.querySelector<HTMLButtonElement>('[data-continue]');
      if (cont) {
        cont.addEventListener('click', () => {
          play('tick');
          advance(Number(step.dataset.index));
        });
      }
    });

    // Wire StepCheck forms.
    type StuckHandle = { arm: () => void; clear: () => void };
    const stuckHandles = new Map<HTMLElement, StuckHandle>();

    steps.forEach((step) => {
      if (!step.hasAttribute('data-check')) return;
      const form = step.querySelector<HTMLFormElement>('[data-check-form]');
      const input = step.querySelector<HTMLInputElement>('[data-check-input]');
      const feedback = step.querySelector<HTMLElement>('[data-check-feedback]');
      const hintEl = step.querySelector<HTMLElement>('[data-check-hint]');
      const submitBtn = step.querySelector<HTMLButtonElement>('[data-check-submit]');
      if (!form || !input || !feedback) return;
      const data: CheckData = {
        answer: Number(step.dataset.answer),
        tolerance: Number(step.dataset.tolerance ?? '0.01'),
      };
      let attempts = 0;

      // Stuck timer: emits tinker:stuck after 30s of no submit.
      // Soft-fails when hint is empty (open Q2 in alive-layer design doc).
      const stepHint = step.dataset.hint?.trim();
      let stuckTimer: number | null = null;
      let armed = false;
      function startStuckTimer(hint: string | undefined) {
        if (!hint) return;
        if (stuckTimer !== null) clearTimeout(stuckTimer);
        stuckTimer = window.setTimeout(() => {
          window.dispatchEvent(
            new CustomEvent(TINKER_EVENT.stuck, { detail: { hint } }),
          );
          stuckTimer = null;
        }, STUCK_MS);
      }
      function clearStuckTimer() {
        if (stuckTimer !== null) {
          clearTimeout(stuckTimer);
          stuckTimer = null;
        }
      }
      stuckHandles.set(step, {
        arm: () => {
          if (armed) return;
          armed = true;
          startStuckTimer(stepHint);
        },
        clear: clearStuckTimer,
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const raw = input.value.trim().replace(/,/g, '.');
        const parsed = Number.parseFloat(raw);
        if (!Number.isFinite(parsed)) {
          feedback.className = 'check-feedback bad';
          feedback.textContent = 'Enter a number.';
          return;
        }
        const delta = Math.abs(parsed - data.answer);
        if (delta <= data.tolerance) {
          feedback.className = 'check-feedback ok';
          feedback.textContent = FEEDBACK_OK;
          input.disabled = true;
          clearStuckTimer();
          // Route through orchestrator: sound + burst + haptic + XP + halo + announce.
          // Orchestrator hard-codes correctFirstTry XP by design (alive-layer §3).
          if (submitBtn) {
            void celebrateCorrect(submitBtn);
          } else {
            // No submit button (shouldn't happen); fall back to bare XP.
            awardXp(XP_AWARD.correctFirstTry, `check:${slug}:${step.dataset.index}`);
          }
          // Reference XP_AWARD.correctRetry to keep the symbol live for future
          // attempt-aware tuning, even though the orchestrator path flat-rates.
          void XP_AWARD.correctRetry;
          void attempts;
          const stepId = step.dataset.stepId;
          const idx = Number(step.dataset.index);
          if (stepId) {
            cancelActiveRating?.();
            cancelActiveRating = mountRatingRow(form, (rating) => {
              cancelActiveRating = null;
              seedFsrsCard({ stepId, lessonSlug: slug, moduleSlug, answer: raw, rating });
              setTimeout(() => advance(idx), RATING_ADVANCE_MS);
            });
          } else {
            // No stable id (shouldn't happen post Phase A); preserve old flow.
            setTimeout(() => advance(idx), 520);
          }
        } else {
          attempts += 1;
          feedback.className = 'check-feedback bad';
          feedback.textContent = delta < 5 * data.tolerance ? FEEDBACK_CLOSE : FEEDBACK_FAR;
          if (attempts >= 2 && hintEl) {
            hintEl.hidden = false;
          }
          clearStuckTimer();
          // Localized shake + announce. No haptic/sound on wrong by design.
          void celebrateWrong(input);
          input.select();
        }
      });
    });

    // Wire StepChoice steps (multiple-choice / select-all answer gate).
    // A choice step carries `data-choice` but not `data-check`, so the
    // numeric branch above skips it; this branch grades it instead.
    steps.forEach((step) => {
      if (!step.hasAttribute('data-choice')) return;
      const options = Array.from(
        step.querySelectorAll<HTMLButtonElement>('[data-choice-option]'),
      );
      const submitBtn = step.querySelector<HTMLButtonElement>('[data-choice-submit]');
      const feedback = step.querySelector<HTMLElement>('[data-choice-feedback]');
      const hintEl = step.querySelector<HTMLElement>('[data-choice-hint]');
      if (options.length === 0 || !submitBtn || !feedback) return;
      const single = step.dataset.single === 'true';
      let attempts = 0;
      let solved = false;

      const clearFeedback = () => {
        feedback.className = 'choice-feedback';
        feedback.textContent = '';
        options.forEach((o) => o.classList.remove('choice-option--wrong'));
      };

      options.forEach((opt) => {
        opt.addEventListener('click', () => {
          if (solved) return;
          const pressed = opt.getAttribute('aria-pressed') === 'true';
          if (single && !pressed) {
            options.forEach((o) => o.setAttribute('aria-pressed', 'false'));
          }
          opt.setAttribute('aria-pressed', pressed ? 'false' : 'true');
          play('tick');
          clearFeedback();
        });
      });

      submitBtn.addEventListener('click', () => {
        if (solved) return;
        const picked = options.filter(
          (o) => o.getAttribute('aria-pressed') === 'true',
        );
        if (picked.length === 0) {
          feedback.className = 'choice-feedback bad';
          feedback.textContent = 'Pick at least one option.';
          return;
        }
        // Correct iff the selected set equals the correct set exactly.
        const allRight = options.every(
          (opt) =>
            (opt.dataset.correct === 'true') ===
            (opt.getAttribute('aria-pressed') === 'true'),
        );
        if (allRight) {
          solved = true;
          feedback.className = 'choice-feedback ok';
          feedback.textContent = FEEDBACK_OK;
          options.forEach((opt) => {
            opt.disabled = true;
            if (opt.dataset.correct === 'true') {
              opt.classList.add('choice-option--right');
            }
          });
          void celebrateCorrect(submitBtn);
          const stepId = step.dataset.stepId;
          const idx = Number(step.dataset.index);
          const block = step.querySelector<HTMLElement>('[data-choice-block]');
          // Submit the picked option indices (source order, matching the
          // build-time manifest's `options` order) so the server can grade
          // is_correct authoritatively, e.g. "1,3". `options` is the live DOM
          // order; <Choice> elements are slotted in source order and never
          // shuffled, so index i here is index i in the manifest.
          const answerIdx = options
            .map((o, i) => (o.getAttribute('aria-pressed') === 'true' ? i : -1))
            .filter((i) => i >= 0)
            .join(',');
          if (stepId && block) {
            cancelActiveRating?.();
            cancelActiveRating = mountRatingRow(block, (rating) => {
              cancelActiveRating = null;
              seedFsrsCard({ stepId, lessonSlug: slug, moduleSlug, answer: answerIdx, rating });
              setTimeout(() => advance(idx), RATING_ADVANCE_MS);
            });
          } else {
            setTimeout(() => advance(idx), 520);
          }
        } else {
          attempts += 1;
          feedback.className = 'choice-feedback bad';
          feedback.textContent = FEEDBACK_FAR;
          options.forEach((opt) => {
            opt.classList.toggle(
              'choice-option--wrong',
              opt.getAttribute('aria-pressed') === 'true' &&
                opt.dataset.correct !== 'true',
            );
          });
          if (attempts >= 2 && hintEl) hintEl.hidden = false;
          void celebrateWrong(submitBtn);
        }
      });
    });

    // Arm the stuck timer for the currently-active check step (if any),
    // and clear all on pagehide.
    function armActiveStuckTimer() {
      const active = steps[unlocked];
      if (!active) return;
      stuckHandles.get(active)?.arm();
    }
    window.addEventListener('pagehide', () => {
      stuckHandles.forEach((h) => h.clear());
    });

    // Reset progress.
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    resetBtn?.addEventListener('click', () => {
      if (!confirm('Start this lesson from the beginning?')) return;
      unlocked = 0;
      lessonCompleteFired = false;
      persist();
      try { localStorage.removeItem(completionKey); } catch { /* ignore */ }
      // Re-enable any disabled StepCheck inputs.
      root.querySelectorAll<HTMLInputElement>('[data-check-input]').forEach((i) => {
        i.disabled = false;
        i.value = '';
      });
      root.querySelectorAll<HTMLElement>('[data-check-feedback]').forEach((el) => {
        el.className = 'check-feedback';
        el.textContent = '';
      });
      // Disarm the active rating timeout, then drop any mounted rating rows
      // so a stale default-to-"good" can't seed a card or advance post-reset.
      cancelActiveRating?.();
      cancelActiveRating = null;
      root.querySelectorAll<HTMLElement>('.rating-row').forEach((el) => el.remove());
      render();
      steps[0]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    render();
    armActiveStuckTimer();
  }

  document.querySelectorAll<HTMLElement>('[data-lesson-slug]').forEach(initLesson);
</script>
