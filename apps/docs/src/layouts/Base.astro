---
import Nav from '../components/Nav.astro';
import '../styles/global.css';
// svelte-mafs core.css wires --mafs-fg / --mafs-grid-color / axis palette to
// our [data-theme="dark"] toggle so widget interiors flip with the rest of
// the page.
import 'svelte-mafs/core.css';

interface Frontmatter {
  title?: string;
  description?: string;
  prose?: boolean;
  fullWidth?: boolean;
  noindex?: boolean;
}

export interface Props extends Frontmatter {
  frontmatter?: Frontmatter;
}

const fm = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? fm.title ?? 'Tinker';
const description =
  Astro.props.description ??
  fm.description ??
  'Rigorous, visual, spaced-repetition-backed learning for adults.';
const prose = Astro.props.prose ?? fm.prose ?? false;
const fullWidth = Astro.props.fullWidth ?? fm.fullWidth ?? false;
// Keep the internal /dev/ audit surface (widget lab, engine smokes, harnesses)
// out of search indexes. It's already excluded from the sitemap; this also
// stops a stray inbound link from getting it crawled. Pages can opt in
// explicitly via the `noindex` prop too.
const noindex =
  Astro.props.noindex ?? fm.noindex ?? Astro.url.pathname.startsWith('/dev/');
const mainClass = [prose ? 'prose' : '', fullWidth ? 'full-width' : ''].filter(Boolean).join(' ');

const titleWithSuffix = title === 'Tinker' ? title : `${title} · Tinker`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Browser chrome (iOS Safari address/status bar) color. Left contentless
        on purpose: the inline script below sets it from the active theme's
        --site-bg token so global.css stays the single source of truth, and
        re-syncs it on every theme toggle. */}
    <meta name="theme-color" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={titleWithSuffix} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <link rel="apple-touch-icon" href="/logo-mark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,700;1,9..144,800&family=Inter:wght@400;500;600;700&family=Nunito:ital,wght@0,700;0,800;0,900;1,800&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
    <title>{titleWithSuffix}</title>

    {/* FOUC-free theme init: must run before paint. */}
    <script is:inline>
      (function () {
        try {
          // Default to light mode. Only an explicit saved choice from the
          // theme toggle overrides it; OS prefers-color-scheme is ignored.
          var saved = localStorage.getItem('theme');
          document.documentElement.dataset.theme =
            saved === 'dark' || saved === 'light' ? saved : 'light';
        } catch (_) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    {/* Keep the browser chrome (iOS address/status bar) matching the theme.
        Reads the active theme's --site-bg token and writes it to the
        theme-color meta on load and on every toggle, so the browser UI goes
        dark with the page instead of staying light. */}
    <script is:inline>
      (function () {
        function sync() {
          var bg = getComputedStyle(document.documentElement)
            .getPropertyValue('--site-bg').trim();
          if (!bg) return;
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', bg);
        }
        // Best-effort now (if styles are already parsed), then once on load,
        // then on every data-theme flip from the theme toggle.
        sync();
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', sync);
        }
        new MutationObserver(sync).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });
      })();
    </script>
    {/* Catch otherwise-silent rejections from `void asyncFn()` patterns + unhandled errors. */}
    <script is:inline>
      window.addEventListener('unhandledrejection', function (e) {
        console.error('[unhandledrejection]', e.reason);
      });
      window.addEventListener('error', function (e) {
        if (e.error) console.error('[window-error]', e.error);
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Nav />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell">
        <p class="copy">© 2026 Tinker · Online learning for everyone. <em>Play. Learn. Grow.</em></p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    border-top: 1px solid var(--site-border);
    color: var(--site-fg-muted);
    font-size: 0.875rem;
    padding: 2rem 0 2.5rem;
  }
  .site-footer .shell {
    max-width: var(--max-shell);
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .site-footer p { margin: 0; }
  .site-footer .copy em {
    font-style: italic;
    color: var(--ink-red);
    font-family: var(--font-display);
    font-weight: 600;
  }
</style>
