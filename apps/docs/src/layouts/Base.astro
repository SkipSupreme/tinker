---
import Nav from '../components/Nav.astro';
import '../styles/global.css';
// svelte-mafs core.css wires --mafs-fg / --mafs-grid-color / axis palette to
// our [data-theme="dark"] toggle so widget interiors flip with the rest of
// the page.
import 'svelte-mafs/core.css';

interface Frontmatter {
  title?: string;
  description?: string;
  prose?: boolean;
  fullWidth?: boolean;
  noindex?: boolean;
}

export interface Props extends Frontmatter {
  frontmatter?: Frontmatter;
}

const fm = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? fm.title ?? 'Tinker';
const description =
  Astro.props.description ??
  fm.description ??
  'Rigorous, visual, spaced-repetition-backed learning for adults.';
const prose = Astro.props.prose ?? fm.prose ?? false;
const fullWidth = Astro.props.fullWidth ?? fm.fullWidth ?? false;
// Keep the internal /dev/ audit surface (widget lab, engine smokes, harnesses)
// out of search indexes. It's already excluded from the sitemap; this also
// stops a stray inbound link from getting it crawled. Pages can opt in
// explicitly via the `noindex` prop too.
const noindex =
  Astro.props.noindex ?? fm.noindex ?? Astro.url.pathname.startsWith('/dev/');
const mainClass = [prose ? 'prose' : '', fullWidth ? 'full-width' : ''].filter(Boolean).join(' ');

const titleWithSuffix = title === 'Tinker' ? title : `${title} · Tinker`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Browser chrome color for browsers that still honor theme-color: Chrome,
        Edge, Firefox-Android, and Safari < 26. Safari 26+ IGNORES this meta and
        instead samples CSS background-color: the sticky nav is kept transparent
        (glass on .site-header::before, which Safari skips) so Safari falls back
        to the <body> background in global.css. Left contentless on purpose: the
        inline script below fills it from the active theme's --site-bg token so
        global.css stays the single source of truth, and re-syncs on toggle. */}
    <meta name="theme-color" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={titleWithSuffix} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <link rel="apple-touch-icon" href="/logo-mark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,700;1,9..144,800&family=Inter:wght@400;500;600;700&family=Nunito:ital,wght@0,700;0,800;0,900;1,800&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
    <title>{titleWithSuffix}</title>

    {/* FOUC-free theme init + browser-chrome sync. Runs before first paint, so
        it CANNOT depend on global.css being parsed yet (Astro injects that
        stylesheet AFTER this inline script). On INITIAL render the chrome color
        comes from CSS: Safari < 26 reads the theme-color meta we set here;
        Safari 26 reads the <body> background (the sticky nav is transparent on
        purpose — see Nav.astro / global.css). The hard part is the LIVE toggle:
        iOS 26 Safari samples the toolbar at render and, by Apple's design, does
        NOT re-sample on JS-driven theme changes, so flipping data-theme restyles
        the page but leaves the toolbar at its load-time color. nudgeChrome() is
        a best-effort re-sample trigger; the reliable path is a reload/navigation,
        which re-runs initial render with the persisted theme. THEME_COLORS
        mirror --site-bg in global.css — keep them in sync. */}
    <script is:inline>
      (function () {
        var THEME_COLORS = { light: '#fdfdfc', dark: '#0e0f10' };
        function currentTheme() {
          return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
        }
        function syncChrome() {
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', THEME_COLORS[currentTheme()]);
        }
        // Best-effort nudge for iOS 26: a plain JS color change won't make Safari
        // re-derive the toolbar, but momentarily inserting a NEW fixed element at
        // the viewport's top edge (in the new theme color) is a render-tree change
        // — the kind of input Safari samples — which can push it to re-derive.
        // We pull it back out after two frames; the <body> background then keeps
        // the toolbar correct. Guards on body (the initial call runs in <head>).
        function nudgeChrome() {
          if (!document.body) return;
          var n = document.createElement('div');
          n.setAttribute('aria-hidden', 'true');
          n.style.cssText =
            'position:fixed;top:0;left:0;right:0;height:8px;z-index:2147483647;' +
            'pointer-events:none;background:' + THEME_COLORS[currentTheme()];
          document.body.appendChild(n);
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { n.remove(); });
          });
        }
        var saved;
        try { saved = localStorage.getItem('theme'); } catch (_) {}
        // Default to light; only an explicit saved choice overrides it (OS
        // prefers-color-scheme is intentionally ignored).
        document.documentElement.dataset.theme =
          saved === 'dark' || saved === 'light' ? saved : 'light';
        // Initial render: just set the meta (no nudge — first paint samples fine).
        syncChrome();
        // On every toggle (data-theme flip): re-sync the meta AND nudge Safari to
        // re-derive the chrome. Never touches data-theme, so no observer loop.
        new MutationObserver(function () {
          syncChrome();
          nudgeChrome();
        }).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });
      })();
    </script>
    {/* Catch otherwise-silent rejections from `void asyncFn()` patterns + unhandled errors. */}
    <script is:inline>
      window.addEventListener('unhandledrejection', function (e) {
        console.error('[unhandledrejection]', e.reason);
      });
      window.addEventListener('error', function (e) {
        if (e.error) console.error('[window-error]', e.error);
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <Nav />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell">
        <p class="copy">© 2026 Tinker · Online learning for everyone. <em>Play. Learn. Grow.</em></p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-footer {
    border-top: 1px solid var(--site-border);
    color: var(--site-fg-muted);
    font-size: 0.875rem;
    padding: 2rem 0 2.5rem;
  }
  .site-footer .shell {
    max-width: var(--max-shell);
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .site-footer p { margin: 0; }
  .site-footer .copy em {
    font-style: italic;
    color: var(--ink-red);
    font-family: var(--font-display);
    font-weight: 600;
  }
</style>
