---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Stream5Preview from '../../components/Stream5Preview.svelte';
---

<Base
  title="Stream 5 preview — Coordinates + Plot"
  description="Temporary preview of Coordinates.Cartesian and the Plot namespace. Replaced by per-component examples in Stream 7 Wave B."
  prose
>
  <h1>Stream 5 preview</h1>
  <p>
    Four live demos using <code>&lt;Mafs&gt;</code>, <code>&lt;Coordinates.Cartesian&gt;</code>,
    and the <code>Plot</code> namespace. Each component is tree-shakeable and
    statically renders on the server — the SVG you see here was produced by
    Astro at build time, then hydrated for interactivity.
  </p>
  <p>
    Stream 7's Wave B will replace this page with one route per component
    (<code>/examples/coordinates</code>, <code>/examples/plot-of-x</code>, etc.).
  </p>

  <Stream5Preview client:load />
</Base>
