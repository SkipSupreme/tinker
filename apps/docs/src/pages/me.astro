---
export const prerender = false;
import { eq } from 'drizzle-orm';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { createAuth, getSession } from '../server/auth';
import { getDb } from '../server/db';
import { userProfile } from '../server/schema';
import { getEnv } from '../server/env';
import { requireSameOrigin } from '../server/middleware';
import { countRetainedSkills } from '../server/steps';
import { getCompletedLessonDates, certScope } from '../server/certificates';

const env = getEnv();
const auth = createAuth({
  DB: env.DB,
  BETTER_AUTH_SECRET: env.BETTER_AUTH_SECRET,
  PUBLIC_SITE_URL: env.PUBLIC_SITE_URL,
});

const session = await getSession(auth, Astro.request.headers);
if (!session) return Astro.redirect('/signin');

const db = getDb(env.DB);

if (Astro.request.method === 'POST') {
  const csrf = requireSameOrigin(Astro.request, env.PUBLIC_SITE_URL);
  if (csrf) return csrf;
  const form = await Astro.request.formData();
  const optIn = form.get('marketing_opt_in') === 'on';
  await db
    .update(userProfile)
    .set({ marketingOptIn: optIn })
    .where(eq(userProfile.userId, session.user.id));
}

const profile = await db
  .select()
  .from(userProfile)
  .where(eq(userProfile.userId, session.user.id))
  .get();

// Mastery framing (Phase G): skills currently retained, FSRS retrievability
// >= 0.9. Counts across every module, so it's the whole-course signal.
const retained = await countRetainedSkills(db, session.user.id);

// Phase K: a quiet "Print certificate" link per fully-completed module, plus
// the whole course if every module is done. Completion is all-or-nothing,
// derived from lesson_view.completedAt — see server/certificates.ts.
const completedDates = await getCompletedLessonDates(db, session.user.id);
const allLessons = await getCollection('lessons', (l) => !l.data.draft);
const modules = (await getCollection('modules', (m) => !m.data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
const moduleCerts = modules.flatMap((m) => {
  const lessons = allLessons
    .filter((l) => l.data.module === m.id)
    .map((l) => ({ slug: l.id, title: l.data.title }));
  const cert = certScope({ scope: m.id, name: m.data.title, lessons, completed: completedDates });
  return cert ? [{ scope: m.id, name: m.data.title }] : [];
});
const courseDone =
  modules.length > 0 &&
  certScope({
    scope: 'all',
    name: 'all',
    lessons: allLessons.map((l) => ({ slug: l.id, title: l.data.title })),
    completed: completedDates,
  }) !== null;
---

<Base title="Account">
  <section class="me">
    <h1>Account</h1>
    <dl class="info">
      <dt>Email</dt>
      <dd>{session.user.email}</dd>
      {session.user.name ? (
        <>
          <dt>Name</dt>
          <dd>{session.user.name}</dd>
        </>
      ) : null}
    </dl>

    <section class="block">
      <h2>Mastery</h2>
      <p class="retained"><strong>{retained}</strong> {retained === 1 ? 'skill' : 'skills'} retained</p>
      <p class="retained-sub">
        {retained > 0
          ? 'Concepts you’d recall right now with at least 90% confidence.'
          : 'Concepts land here once you’ve reviewed them and they’ve stuck.'}
        {' '}Keep them warm at <a href="/review">review</a>.
      </p>
    </section>

    {moduleCerts.length > 0 && (
      <section class="block">
        <h2>Certificates</h2>
        <ul class="certs">
          {courseDone && (
            <li>
              <span>The whole course</span>
              <a href="/me/certificate/all/">Print certificate</a>
            </li>
          )}
          {moduleCerts.map((c) => (
            <li>
              <span>{c.name}</span>
              <a href={`/me/certificate/${c.scope}/`}>Print certificate</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <form method="POST" class="block">
      <h2>Email preferences</h2>
      <label class="opt-in">
        <input type="checkbox" name="marketing_opt_in" value="on" checked={profile?.marketingOptIn ?? false} />
        <span>Email me when new modules drop.</span>
      </label>
      <button type="submit">Save preferences</button>
    </form>

    <section class="block danger">
      <h2>Delete account</h2>
      <p>Permanently delete your account and all progress. This cannot be undone.</p>
      <button type="button" id="delete-account">Delete my account</button>
    </section>
  </section>
</Base>

<script is:inline>
  document.getElementById('delete-account')?.addEventListener('click', async () => {
    if (!confirm('This permanently deletes your account, progress, bookmarks, and notes. Continue?')) return;
    const res = await fetch('/api/me', {
      method: 'DELETE',
      credentials: 'same-origin',
    });
    if (res.status === 204) {
      location.href = '/';
    } else {
      alert('Could not delete account. Try signing out and back in, then retry.');
    }
  });
</script>

<style>
  .me {
    max-width: 640px;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0 0 1.5rem;
  }
  h2 {
    font-size: 1.1rem;
    margin: 0 0 0.75rem;
  }
  .info {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.5rem 1rem;
    margin: 0 0 2rem;
  }
  .info dt { color: var(--site-fg-muted); font-size: 0.9rem; }
  .info dd { margin: 0; }
  .retained {
    margin: 0 0 0.35rem;
    font-family: var(--font-game);
    font-variant-numeric: tabular-nums;
    font-size: 1.1rem;
  }
  .retained strong {
    font-weight: 700;
    font-size: 1.5rem;
  }
  .retained-sub {
    margin: 0;
    color: var(--site-fg-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .retained-sub a { color: var(--site-fg); }
  .certs { list-style: none; padding: 0; margin: 0; }
  .certs li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--site-border);
  }
  .certs li:last-child { border-bottom: none; }
  .certs li span { font-size: 0.95rem; }
  .certs li a {
    color: var(--site-fg-muted);
    font-size: 0.85rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .certs li a:hover { color: var(--site-fg); text-decoration: underline; }
  .block {
    padding: 1.5rem;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    margin-bottom: 1rem;
    background: var(--site-bg);
  }
  .block.danger {
    border-color: color-mix(in srgb, var(--site-error) 30%, var(--site-border));
  }
  .opt-in { display: flex; gap: 0.5rem; align-items: flex-start; margin-bottom: 1rem; }
  .opt-in input { margin-top: 0.3rem; }
  form button {
    padding: 0.6rem 1.2rem;
    background: var(--site-fg);
    color: var(--site-bg);
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
  }
  .danger button {
    padding: 0.6rem 1.2rem;
    background: transparent;
    color: var(--site-error);
    border: 1px solid var(--site-error);
    border-radius: var(--radius-md);
    cursor: pointer;
    font-weight: 600;
  }
  .danger button:hover { background: var(--site-error); color: var(--site-bg); }
</style>
