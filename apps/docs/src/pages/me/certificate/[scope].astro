---
export const prerender = false;
import { eq } from 'drizzle-orm';
import { getCollection, getEntry } from 'astro:content';
import '../../../styles/global.css';
import { createAuth, getSession } from '../../../server/auth';
import { getDb } from '../../../server/db';
import { getEnv } from '../../../server/env';
import { userProfile } from '../../../server/schema';
import { getCompletedLessonDates, certScope, type CertScope } from '../../../server/certificates';

const env = getEnv();
const auth = createAuth({
  DB: env.DB,
  BETTER_AUTH_SECRET: env.BETTER_AUTH_SECRET,
  PUBLIC_SITE_URL: env.PUBLIC_SITE_URL,
});

const session = await getSession(auth, Astro.request.headers);
if (!session) return Astro.redirect('/signin');

const db = getDb(env.DB);
const { scope } = Astro.params;
if (!scope) return Astro.redirect('/me');

const completed = await getCompletedLessonDates(db, session.user.id);
const allLessons = await getCollection('lessons', (l) => !l.data.draft);
const byOrder = (a: { data: { order: number }; id: string }, b: { data: { order: number }; id: string }) =>
  a.data.order - b.data.order || a.id.localeCompare(b.id);

// `items` are what the certificate lists as "covered": lessons for a module
// scope, modules for the whole-course scope (so `all` stays one A4 page).
let cert: CertScope | null = null;
let coveredLabel = 'Lessons completed';
let items: string[] = [];

if (scope === 'all') {
  const course = (await getCollection('courses', (c) => !c.data.draft))[0];
  const modules = (await getCollection('modules', (m) => !m.data.draft)).sort(byOrder);
  const lessons = [...allLessons].sort(byOrder).map((l) => ({ slug: l.id, title: l.data.title }));
  cert = certScope({ scope: 'all', name: course?.data.title ?? 'the full course', lessons, completed });
  coveredLabel = 'Modules completed';
  items = modules
    .filter((m) => allLessons.some((l) => l.data.module === m.id))
    .map((m) => m.data.title);
} else {
  const moduleEntry = await getEntry('modules', scope);
  if (!moduleEntry || moduleEntry.data.draft) return Astro.redirect('/me');
  const scopeLessons = allLessons.filter((l) => l.data.module === scope).sort(byOrder);
  cert = certScope({
    scope,
    name: moduleEntry.data.title,
    lessons: scopeLessons.map((l) => ({ slug: l.id, title: l.data.title })),
    completed,
  });
  items = scopeLessons.map((l) => l.data.title);
}

if (!cert) return Astro.redirect('/me');

const profile = await db
  .select()
  .from(userProfile)
  .where(eq(userProfile.userId, session.user.id))
  .get();
const learner =
  profile?.displayName?.trim() || session.user.name?.trim() || session.user.email.split('@')[0];
const dateStr = cert.completedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{`Certificate · ${cert.name} · Tinker`}</title>
    <link rel="icon" type="image/png" href="/logo-mark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,700;1,9..144,800&family=Inter:wght@400;500;600;700&family=Nunito:ital,wght@0,700;0,800;0,900;1,800&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
  </head>
  <body>
    <div class="bar no-print">
      <a href="/me" class="back">← Account</a>
      <button type="button" id="print-btn">Print</button>
    </div>

    <main class="sheet">
      <article class="cert">
        <p class="wordmark">Tinker<em class="bang">!</em></p>
        <p class="kicker">Certificate of completion</p>
        <h1 class="who">{learner}</h1>
        <p class="finished">finished</p>
        <p class="scope-name">{cert.name}</p>
        <p class="date">{dateStr}</p>

        <hr />

        <p class="covered-label">{coveredLabel}</p>
        <ul class="covered">
          {items.map((title) => <li>{title}</li>)}
        </ul>

        <p class="fridge">
          you finished this. nice. here’s something to print and stick on the fridge if that’s your
          kind of thing.
        </p>
      </article>
    </main>

    <script is:inline>
      document.getElementById('print-btn')?.addEventListener('click', function () {
        window.print();
      });
    </script>

    <style>
      body {
        background: var(--band-cream);
        color: var(--site-fg);
        min-height: 100vh;
        margin: 0;
      }
      .bar {
        /* width:100% + box-sizing is load-bearing: global.css sets
           `body { display:flex; flex-direction:column }`, and a flex item with
           `margin:0 auto` shrinks to its content instead of stretching — which
           collapsed space-between and made the back link touch the Print pill.
           An explicit width restores the full row; auto margins then only
           center the capped 820px on wide screens. */
        width: 100%;
        max-width: 820px;
        box-sizing: border-box;
        margin: 0 auto;
        padding: 1.25rem 1.5rem 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .bar .back {
        color: var(--site-fg-muted);
        text-decoration: none;
        font-size: 0.95rem;
      }
      .bar .back:hover { color: var(--site-fg); }
      #print-btn {
        padding: 0.55rem 1.4rem;
        background: var(--cta);
        color: var(--cta-fg);
        border: none;
        border-radius: var(--radius-pill, 999px);
        font-family: var(--font-game);
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
      }
      #print-btn:hover { background: var(--cta-hover); }

      .sheet {
        max-width: 820px;
        margin: 1.5rem auto 3rem;
        padding: 0 1.5rem;
      }
      .cert {
        background: var(--site-bg);
        border: 1px solid var(--site-border);
        border-radius: var(--radius-lg);
        padding: 3.5rem 3rem;
        text-align: center;
      }
      .wordmark {
        font-family: var(--font-wordmark);
        font-weight: 800;
        font-size: 1.4rem;
        margin: 0 0 2.5rem;
        letter-spacing: -0.01em;
      }
      .wordmark .bang {
        font-style: normal;
        color: var(--ink-red);
      }
      .kicker {
        margin: 0 0 1.25rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.75rem;
        font-family: var(--font-game);
        color: var(--site-fg-muted);
      }
      .who {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 2.4rem;
        line-height: 1.1;
        margin: 0 0 0.5rem;
      }
      .finished {
        margin: 0 0 0.4rem;
        color: var(--site-fg-muted);
        font-style: italic;
        font-family: var(--font-display);
      }
      .scope-name {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.5rem;
        margin: 0 0 1.25rem;
      }
      .date {
        margin: 0;
        font-family: var(--font-game);
        font-variant-numeric: tabular-nums;
        color: var(--site-fg-muted);
        font-size: 0.95rem;
      }
      hr {
        border: none;
        border-top: 1px solid var(--site-border);
        margin: 2.25rem auto;
        width: 60%;
      }
      .covered-label {
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.7rem;
        font-family: var(--font-game);
        color: var(--site-fg-muted);
        margin: 0 0 0.85rem;
      }
      .covered {
        list-style: none;
        padding: 0;
        margin: 0 auto 2.25rem;
        max-width: 32rem;
        columns: 2;
        column-gap: 2rem;
        text-align: left;
      }
      .covered li {
        font-size: 0.92rem;
        line-height: 1.5;
        padding: 0.1rem 0;
        break-inside: avoid;
      }
      .covered li::before {
        content: "·";
        color: var(--ink-red);
        margin-right: 0.5rem;
        font-weight: 700;
      }
      .fridge {
        margin: 0;
        color: var(--site-fg-muted);
        font-size: 0.9rem;
        line-height: 1.6;
        max-width: 30rem;
        margin: 0 auto;
      }

      @media (max-width: 540px) {
        .cert { padding: 2.5rem 1.5rem; }
        .who { font-size: 2rem; }
        .covered { columns: 1; }
      }

      @media print {
        .no-print { display: none !important; }
        body { background: #fff; }
        .sheet { margin: 0; padding: 0; max-width: none; }
        .cert { border: none; border-radius: 0; padding: 0; }
        @page { size: A4; margin: 22mm; }
      }
    </style>
  </body>
</html>
