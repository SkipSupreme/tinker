---
export const prerender = false;
import { eq } from 'drizzle-orm';
import Base from '../layouts/Base.astro';
import { createAuth, getSession } from '../server/auth';
import { getDb } from '../server/db';
import { userProfile } from '../server/schema';
import { getEnv } from '../server/env';
import { requireSameOrigin } from '../server/middleware';

const env = getEnv();
const auth = createAuth({
  DB: env.DB,
  BETTER_AUTH_SECRET: env.BETTER_AUTH_SECRET,
  PUBLIC_SITE_URL: env.PUBLIC_SITE_URL,
});

const session = await getSession(auth, Astro.request.headers);
if (!session) return Astro.redirect('/auth?mode=signin');

const db = getDb(env.DB);

const existing = await db
  .select()
  .from(userProfile)
  .where(eq(userProfile.userId, session.user.id))
  .get();

if (!existing) {
  await db.insert(userProfile).values({
    userId: session.user.id,
    marketingOptIn: false,
  });
}

if (Astro.request.method === 'POST') {
  const csrf = requireSameOrigin(Astro.request, env.PUBLIC_SITE_URL);
  if (csrf) return csrf;
  const form = await Astro.request.formData();
  const optIn = form.get('marketing_opt_in') === 'on';
  await db
    .update(userProfile)
    .set({ marketingOptIn: optIn, onboardedAt: new Date() })
    .where(eq(userProfile.userId, session.user.id));
  // Both buttons complete onboarding; only the destination differs.
  return Astro.redirect(form.get('next') === 'course' ? '/courses/ml-math' : '/diagnostic');
}

if (existing?.onboardedAt) return Astro.redirect('/');
---

<Base title="Welcome">
  <section class="welcome">
    <h1>You're in.</h1>
    <p class="lede">
      One course is live: <a href="/courses/ml-math">Math for Machine Learning</a>.
      Nineteen modules, from arithmetic to a transformer you train yourself in your browser.
    </p>
    <p class="sub">
      Not sure where to begin? A short adaptive check finds your starting point so you
      skip what you already know — usually under a dozen questions, no grade.
    </p>
    <form method="POST">
      <label class="opt-in">
        <input type="checkbox" name="marketing_opt_in" value="on" />
        <span>Email me when new modules drop. Unsubscribe any time.</span>
      </label>
      <div class="actions">
        <button type="submit" name="next" value="diagnostic" class="primary">
          Find your starting point
        </button>
        <button type="submit" name="next" value="course" class="ghost">
          Browse the full map instead
        </button>
      </div>
    </form>
  </section>
</Base>

<style>
  .welcome {
    max-width: 520px;
    margin: 4rem auto;
    padding: 2rem 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }
  .lede { color: var(--site-fg-muted); margin: 0 0 1rem; }
  .sub { color: var(--site-fg-muted); margin: 0 0 2rem; font-size: 0.95rem; line-height: 1.55; }
  form { display: flex; flex-direction: column; gap: 1.25rem; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; }
  .opt-in {
    display: flex;
    gap: 0.65rem;
    align-items: flex-start;
    padding: 1rem;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    background: var(--site-surface);
    font-size: 0.95rem;
    cursor: pointer;
  }
  .opt-in input { margin-top: 0.25rem; }
  .primary {
    padding: 0.7rem 1.4rem;
    background: var(--cta);
    color: var(--cta-fg);
    border: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    cursor: pointer;
    transition: background-color 140ms ease, transform 140ms ease;
  }
  .primary:hover { background: var(--cta-hover); transform: translateY(-1px); }
  .ghost {
    padding: 0.7rem 1.1rem;
    background: transparent;
    color: var(--site-fg-muted);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    font-weight: 500;
    cursor: pointer;
    transition: color 140ms ease, border-color 140ms ease;
  }
  .ghost:hover { color: var(--site-fg); border-color: var(--site-fg); }
  @media (prefers-reduced-motion: reduce) {
    .primary:hover { transform: none; }
  }
</style>
