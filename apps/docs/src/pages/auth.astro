---
export const prerender = false;
import Base from '../layouts/Base.astro';
import AuthForm from '../components/auth/AuthForm.svelte';
import { resolveAuthError } from '../lib/auth-errors';

const url = new URL(Astro.request.url);
const params = url.searchParams;
const errorMessage = resolveAuthError(params);
const mode = params.get('mode') === 'signup' ? 'signup' : 'signin';
// Only accept same-origin relative paths. Block protocol-relative URLs (//evil),
// backslash tricks (/\evil), and any absolute URL. Anything else falls back to
// the safe default. Without this, an attacker can craft /auth?callbackURL=
// https://attacker.example and steal users after sign-in via location.assign().
const rawCallback = params.get('callbackURL') ?? '/welcome';
const callbackURL = /^\/(?![\\/])/.test(rawCallback) ? rawCallback : '/welcome';
const title = mode === 'signup' ? 'Sign up' : 'Sign in';
---

<Base title={title}>
  <AuthForm client:load mode={mode} error={errorMessage} callbackURL={callbackURL} />
</Base>
