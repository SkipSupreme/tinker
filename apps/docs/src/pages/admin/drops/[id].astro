---
export const prerender = false;
import { eq } from 'drizzle-orm';
import Base from '../../../layouts/Base.astro';
import { requireAdmin } from '../../../server/admin';
import { emailDrop } from '../../../server/schema';
import { getEnv } from '../../../server/env';

const env = getEnv();
const guard = await requireAdmin(Astro.request, {
  DB: env.DB,
  BETTER_AUTH_SECRET: env.BETTER_AUTH_SECRET,
  GOOGLE_CLIENT_ID: env.GOOGLE_CLIENT_ID,
  GOOGLE_CLIENT_SECRET: env.GOOGLE_CLIENT_SECRET,
  GITHUB_CLIENT_ID: env.GITHUB_CLIENT_ID,
  GITHUB_CLIENT_SECRET: env.GITHUB_CLIENT_SECRET,
  RESEND_API_KEY: env.RESEND_API_KEY,
  PUBLIC_SITE_URL: env.PUBLIC_SITE_URL,
});
if (!guard.ok) return guard.response;

const id = Astro.params.id;
const drop = id
  ? await guard.db.select().from(emailDrop).where(eq(emailDrop.id, id)).get()
  : null;

if (!drop) return new Response('not found', { status: 404 });
---

<Base title={`Drop · ${drop.subject}`}>
  <section class="drop">
    <p><a href="/admin">← back</a></p>
    <h1>{drop.subject}</h1>
    <dl>
      <dt>Sent</dt><dd>{drop.sentAt.toLocaleString()}</dd>
      <dt>Audience</dt><dd>{drop.targetCount}</dd>
      <dt>Sent successfully</dt><dd>{drop.sentCount} of {drop.targetCount}</dd>
      {drop.lessonSlug ? <><dt>Lesson</dt><dd>{drop.lessonSlug}</dd></> : null}
    </dl>
    <h2>Body</h2>
    <pre class="body-preview"><code>{drop.bodyMd}</code></pre>
  </section>
</Base>

<style>
  .drop { max-width: 720px; margin: 3rem auto; padding: 0 1.5rem; }
  h1 { font-family: var(--font-display); font-size: 1.75rem; margin: 0.5rem 0 1.5rem; }
  h2 { font-size: 1.05rem; margin: 1.5rem 0 0.5rem; }
  dl { display: grid; grid-template-columns: 12rem 1fr; gap: 0.4rem 1rem; margin: 0; }
  dt { color: var(--site-fg-muted); font-size: 0.9rem; }
  dd { margin: 0; font-size: 0.9rem; }
  .body-preview {
    padding: 1rem;
    background: var(--site-surface);
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    overflow: auto;
    white-space: pre-wrap;
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
</style>
