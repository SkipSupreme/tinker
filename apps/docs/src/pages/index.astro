---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Tinker from '../components/brand/Tinker.svelte';
import FloatingMath from '../components/brand/FloatingMath.svelte';
import EmbeddingPluck from '../components/demos/EmbeddingPluck.svelte';
import CourseAtlas from '../components/course/CourseAtlas.svelte';

// === Course Atlas data: arcs -> modules -> lessons, built at build time from
// the content collections so the homepage shows the entire course. ===
const courses = await getCollection('courses');
const course = courses.find((c) => c.id === 'ml-math') ?? courses[0];

const allModules = await getCollection('modules', (m) => !m.data.draft);
const allLessons = await getCollection('lessons', (l) => !l.data.draft);
const moduleById = new Map(allModules.map((m) => [m.id, m]));

type LessonEntry = (typeof allLessons)[number];
const lessonsByModule = new Map<string, LessonEntry[]>();
for (const l of allLessons) {
  const arr = lessonsByModule.get(l.data.module) ?? [];
  arr.push(l);
  lessonsByModule.set(l.data.module, arr);
}
for (const arr of lessonsByModule.values()) {
  arr.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}

// Arc accent tokens. sea -> teal -> red (keystone arc) -> orange -> pink.
// No purple; sun is reserved for XP per DESIGN.md.
const ARC_COLORS: Record<string, string> = {
  'arc-0-foundations': 'var(--ink-sea)',
  'arc-1-prereq-math': 'var(--ink-teal)',
  'arc-2-ml-foundations': 'var(--ink-red)',
  'arc-3-transformers': 'var(--ink-orange)',
  'arc-4-capstone': 'var(--ink-pink)',
};
const KEYSTONE = new Set(['m12-backpropagation']);

const atlasArcs = course.data.arcs.map((arc) => {
  const modules = arc.modules.flatMap((id) => {
    const m = moduleById.get(id);
    if (!m) return [];
    const lessons = (lessonsByModule.get(m.id) ?? []).map((l) => ({
      slug: l.id,
      title: l.data.title,
      order: l.data.order ?? 0,
      minutes: l.data.estimatedMinutes,
    }));
    const minutes = lessons.reduce((s, l) => s + l.minutes, 0);
    return [
      {
        id: m.id,
        anchor: m.id.split('-')[0],
        order: m.data.order,
        title: m.data.title,
        summary: m.data.summary,
        minutes,
        keystone: KEYSTONE.has(m.id),
        lessons,
      },
    ];
  });
  return {
    id: arc.id,
    title: arc.title,
    description: arc.description,
    color: ARC_COLORS[arc.id] ?? 'var(--ink-red)',
    modules,
    moduleCount: modules.length,
    lessonCount: modules.reduce((s, mm) => s + mm.lessons.length, 0),
    minutes: modules.reduce((s, mm) => s + mm.minutes, 0),
  };
});

const totals = {
  arcs: atlasArcs.length,
  modules: atlasArcs.reduce((s, a) => s + a.moduleCount, 0),
  lessons: atlasArcs.reduce((s, a) => s + a.lessonCount, 0),
  minutes: atlasArcs.reduce((s, a) => s + a.minutes, 0),
};
---

<Base
  title="Tinker"
  description="Play with ideas. Learn for real. Grow fast. Mini lessons, instant feedback, and joyful wins for curious kids, teens, and grown-ups."
  fullWidth
>
  <!-- Pre-hydration capture for hero events. The widget hydrates as a
       client:load island and may dispatch tinker:hero:* events before
       Tinker.svelte (client:visible) attaches. This inline capture-phase
       listener buffers events to window.__tinkerHeroBuffer so Tinker can
       drain them on mount. ARCH-3 / TENSION-3 from the plan-eng-review. -->
  <script is:inline>
    (function () {
      if (typeof window === 'undefined') return;
      window.__tinkerHeroBuffer = window.__tinkerHeroBuffer || [];
      var names = [
        'tinker:hero:focus',
        'tinker:hero:drag',
        'tinker:hero:threshold',
        'tinker:hero:success',
        'tinker:hero:idle',
      ];
      for (var i = 0; i < names.length; i++) {
        window.addEventListener(names[i], function (e) {
          if (window.__tinkerHeroBuffer && window.__tinkerHeroBuffer.length < 64) {
            window.__tinkerHeroBuffer.push(e);
          }
        }, true);
      }
    })();
  </script>

  <section class="hero band band-onyx">
    <FloatingMath client:visible />
    <div class="shell">
      <div class="hero-grid" data-hero-region>
        <div class="hero-copy">
          <h1 class="hero-headline">
            <span class="line">Learn by playing</span>
            <span class="line">with the <span class="ink-red"><em>math.</em></span></span>
          </h1>
          <p class="lede">
            Drag a letter. Watch the constellation react. That's not a
            decoration. It's the core idea behind embeddings, the foundation
            of every modern AI model. Tinker teaches the math underneath
            machine learning by letting you touch it.
          </p>
          <div class="cta-row">
            <a class="btn primary" href="/signup">Sign up, it's free</a>
            <a class="btn secondary" href="/lessons">Explore the course</a>
          </div>
          <p class="hero-note">
            {totals.lessons} interactive lessons · free in your browser
          </p>
        </div>
        <div class="hero-stage">
          <div class="hero-mascot">
            <Tinker client:visible size="clamp(110px, 13vw, 160px)" />
          </div>
          <div class="hero-widget">
            <EmbeddingPluck client:load hero={true} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three concrete proof-cards: real things you build in the course.
       Not generic feature pills, but actual module callbacks with the
       widget, the moment, the payoff. -->
  <section class="band band-white proof-band">
    <div class="shell">
      <p class="kicker kicker-red">What you'll actually build</p>
      <h2 class="proof-headline">
        Three moments. <em>Pick the one you want first.</em>
      </h2>

      <ol class="proof-grid">
        <li class="proof-card">
          <div class="proof-num"><span>12</span></div>
          <h3 class="proof-title">Backprop, from scratch</h3>
          <p class="proof-desc">
            Build micrograd one node at a time. Watch the gradient flow
            backward through a tanh, see how <code>loss.backward()</code>
            actually works. The keystone module of the course.
          </p>
          <a class="proof-link" href="#m12">
            Module 12 · Backpropagation →
          </a>
        </li>

        <li class="proof-card">
          <div class="proof-num"><span>15</span></div>
          <h3 class="proof-title">Attention, as a soft dictionary</h3>
          <p class="proof-desc">
            The thing you played with up top is an embedding, the
            foundation of attention. Drag a query vector, watch it pivot
            toward the right keys. Build the math behind the T in GPT.
          </p>
          <a class="proof-link" href="#m15">
            Module 15 · Attention →
          </a>
        </li>

        <li class="proof-card">
          <div class="proof-num"><span>18</span></div>
          <h3 class="proof-title">A real transformer, in your browser</h3>
          <p class="proof-desc">
            Capstone: 4 layers, 4 heads, ~200k params. Trains in ~5
            minutes on WebGPU. Generates Shakespeare-flavored nonsense.
            Yours to keep.
          </p>
          <a class="proof-link" href="#m18">
            Module 18 · Capstone →
          </a>
        </li>
      </ol>
    </div>
  </section>

  <!-- The whole course, arc by arc: every module and every lesson rendered as
       an interactive climb. Replaces the old four-arc teaser. Each module node
       expands to reveal its lessons; signed-in learners see progress light up. -->
  <section class="band band-cream atlas-band">
    <div class="atlas-intro">
      <p class="kicker kicker-red">The whole course</p>
      <h2 class="atlas-headline">
        Every lesson. <em>One continuous climb.</em>
      </h2>
      <p class="atlas-lede">
        From <code class="atlas-code">f(x) = x²</code> to a transformer you train
        yourself. Open any module to see its lessons. Sign in and the map lights
        up with what you've finished.
      </p>
    </div>
    <CourseAtlas client:visible arcs={atlasArcs} totals={totals} />
    <div class="atlas-cta">
      <a class="btn secondary" href="/lessons">Open the full course →</a>
    </div>
  </section>

  <!-- Closing CTA: dark hero band, premium feel. The work is the pitch. -->
  <section class="band band-onyx closing-band">
    <div class="shell tall">
      <h2 class="closing-headline">
        There's a math underneath every model.
        <em class="closing-em">You can touch it.</em>
      </h2>
      <p class="closing-sub">
        Five arcs, nineteen modules, ninety-two lessons, free in your browser.
        From <code class="closing-code">f(x) = x²</code> to a transformer you
        train yourself on the GPU in your laptop.
      </p>
      <div class="cta-row closing-cta-row">
        <a class="btn primary" href="/signup">Sign up, it's free</a>
        <a class="btn secondary" href="/lessons">Explore the course</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .band {
    width: 100%;
    padding: clamp(3rem, 7vw, 5.5rem) 1.25rem;
    position: relative;
    overflow: hidden;
  }
  /* DESIGN.md §Spacing: tighter band padding under 380px. */
  @media (max-width: 380px) {
    .band { padding: clamp(2rem, 6vw, 3rem) 1rem; }
  }
  .band-cream    { background: var(--band-cream); }
  .band-white    { background: var(--band-white); }
  .band-onyx {
    /* Fallback for engines without color-mix() (iOS Safari < 16.2): the whole
       multi-layer background shorthand below is invalid there and gets dropped,
       so declare the solid band first to keep the section from rendering with
       no background. Modern engines apply the radial-accent layers. */
    background: var(--band-onyx);
    background:
      radial-gradient(circle at 25% 30%, color-mix(in srgb, var(--ink-red) 22%, transparent), transparent 55%),
      radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--ink-coral) 14%, transparent), transparent 55%),
      var(--band-onyx);
    color: var(--band-dark-fg);
  }
  .shell {
    max-width: var(--max-hero);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .shell.tall { text-align: center; padding: 1rem 0 2rem; }

  /* === Hero ===
     One viewport, one composition: copy + CTAs on the left (always above the
     fold), the live widget as the stage on the right with the mascot perched
     on its top edge. min() caps the svh stretch so ultrawide monitors don't
     inflate the band into a void. */
  .hero {
    display: flex;
    align-items: center;
    min-height: min(calc(100svh - var(--nav-height)), 760px);
    padding: clamp(1.5rem, 3vw, 3rem) 1.25rem clamp(2rem, 4vw, 3.5rem);
  }
  .hero .shell { width: 100%; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    /* Copy is first in source order: headline, lede, and CTAs stack above
       the widget stage on phones, so the primary action stays in reach. */
  }
  @media (max-width: 640px) {
    .hero { padding: 1.25rem 1rem 2rem; }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 700;
    /* Locked Display token (DESIGN.md §Typography scale). */
    font-size: clamp(2.1rem, 5.5vw, 4.25rem);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0 0 1.4rem;
    text-wrap: balance;
  }
  .hero-headline .line {
    display: block;
  }
  .hero-headline em {
    font-style: italic;
    font-weight: 700;
    /* Per-verb color set via .ink-red/coral/sun spans. */
  }
  .ink-red    { color: var(--ink-red); }

  .lede {
    font-size: clamp(1.05rem, 1.55vw, 1.25rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--band-dark-fg) 85%, transparent);
    max-width: 36ch;
    margin: 0 0 1.25rem;
  }

  /* === CTA pair: pressable buttons (DESIGN.md §Color, pressable recipe) ===
     The resting button sits on a solid 4px "shelf" (box-shadow 0 4px 0).
     Hover lifts 1px (shelf grows to 5px, bottom edge stays planted); active
     travels down 4px and collapses the shelf, so a click feels mechanical.
     Focus ring comes from the global :focus-visible (sea blue). */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin: 0 0 var(--space-md);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: var(--space-sm) 1.75rem;
    border-radius: var(--radius-pill);
    font: inherit;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    line-height: 1.2;
    text-align: center;
    white-space: normal;
    border: 0;
    cursor: pointer;
    transition: transform 140ms ease, background-color 140ms ease,
                box-shadow 140ms ease, border-color 140ms ease;
  }
  .btn.primary {
    background: var(--cta);
    color: var(--cta-fg);
    box-shadow: 0 4px 0 var(--cta-edge);
  }
  .btn.primary:hover {
    background: var(--cta-hover);
    transform: translateY(-1px);
    box-shadow: 0 5px 0 var(--cta-edge);
  }
  .btn.primary:active {
    transform: translateY(4px);
    box-shadow: 0 0 0 var(--cta-edge);
  }
  .btn.secondary {
    background: var(--demo-card);
    color: var(--site-fg);
    border: 2px solid var(--site-border);
    box-shadow: 0 4px 0 var(--site-border);
  }
  .btn.secondary:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--site-fg) 25%, var(--site-bg));
    box-shadow: 0 5px 0 color-mix(in srgb, var(--site-fg) 25%, var(--site-bg));
  }
  .btn.secondary:active {
    transform: translateY(4px);
    box-shadow: 0 0 0 var(--site-border);
  }
  /* Phones: stack the pair full-width so the primary reads as THE action. */
  @media (max-width: 640px) {
    .cta-row {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-sm);
    }
  }

  /* Microproof line under the CTAs: the one stat that matters, computed
     from the content collections (never hand-maintained). */
  .hero-note {
    margin: 0;
    font-family: var(--font-game);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--band-dark-fg) 65%, transparent);
  }

  /* === Hero stage: widget card + perched mascot ===
     The stage reserves headroom (padding-top) so the apple can overlap the
     card's top edge without clipping against the band's overflow:hidden.
     <Tinker /> handles its own glow, idle bob, hover-tilt, click bounce,
     and reduced-motion fallback. */
  .hero-stage {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin-left: auto;
    padding-top: clamp(64px, 7vw, 92px);
    min-width: 0;
  }
  .hero-mascot {
    position: absolute;
    top: clamp(64px, 7vw, 92px);
    right: clamp(12px, 5%, 28px);
    transform: translateY(-68%);
    z-index: 2;
  }
  .hero-widget {
    width: 100%;
  }
  @media (max-width: 900px) {
    .hero-stage {
      margin: 0 auto;
      max-width: 480px;
    }
  }

  .kicker {
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 700;
    margin: 0 0 0.85rem;
  }
  .kicker-red { color: var(--ink-red); }

  /* === Proof band: three things you'll actually build. === */
  .proof-band { padding: clamp(3rem, 6vw, 5rem) 1.25rem; }
  .proof-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 2rem;
    /* Constrain so the headline wraps to two balanced lines instead of
       running edge-to-edge across the full band on wide viewports. */
    max-width: 20ch;
    text-wrap: balance;
  }
  .proof-headline em { font-style: italic; color: var(--ink-coral); font-weight: 700; }
  .proof-grid {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .proof-card {
    position: relative;
    padding: 1.5rem 1.4rem 1.4rem;
    border: 1.5px solid var(--site-border);
    border-radius: 20px;
    background: var(--site-bg);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .proof-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--ink-red) 40%, transparent);
    box-shadow: 0 18px 32px -16px color-mix(in srgb, var(--ink-red) 35%, transparent);
  }
  .proof-num {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 800;
    font-size: 3rem;
    line-height: 1;
    color: color-mix(in srgb, var(--ink-red) 18%, transparent);
    pointer-events: none;
  }
  .proof-num span { display: inline-block; }
  .proof-title {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: 1.25rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
    max-width: 14ch;
  }
  .proof-desc {
    margin: 0;
    color: var(--site-fg-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .proof-desc code {
    background: var(--demo-stage);
    color: var(--site-fg);
    padding: 0.05em 0.35em;
    border-radius: 4px;
    font-size: 0.88em;
  }
  .proof-link {
    margin-top: auto;
    padding-top: 0.4rem;
    color: var(--ink-red);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
    border-top: 1px dashed color-mix(in srgb, var(--site-fg) 14%, transparent);
  }
  .proof-link:hover { color: var(--ink-coral); }

  /* === Atlas band: the whole course as an interactive climb. === */
  .atlas-band { padding: clamp(3rem, 6vw, 5rem) 1.25rem; }
  .atlas-intro {
    max-width: var(--max-shell);
    margin: 0 auto 2.5rem;
  }
  .atlas-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 0.75rem;
    max-width: 20ch;
    text-wrap: balance;
  }
  .atlas-headline em { font-style: italic; color: var(--ink-red); font-weight: 700; }
  .atlas-lede {
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--site-fg-muted);
    max-width: 56ch;
    margin: 0;
  }
  .atlas-code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.05em 0.4em;
    border-radius: 5px;
    background: color-mix(in srgb, var(--site-fg) 8%, transparent);
    color: var(--site-fg);
    white-space: nowrap;
  }
  .atlas-cta {
    max-width: var(--max-shell);
    margin: 2.5rem auto 0;
    display: flex;
    justify-content: center;
  }

  /* === Closing CTA band: premium dark, the work is the pitch. === */
  .closing-band {
    padding: clamp(4rem, 8vw, 7rem) 1.25rem;
  }
  .closing-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 auto 1.25rem;
    max-width: 28ch;
    text-wrap: balance;
  }
  .closing-em {
    display: block;
    font-style: italic;
    color: var(--ink-red);
    font-weight: 700;
  }
  .closing-sub {
    margin: 0 auto 2rem;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--band-dark-fg) 75%, transparent);
    max-width: 44ch;
  }
  .closing-code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 0.05em 0.4em;
    border-radius: 5px;
    background: color-mix(in srgb, var(--band-dark-fg) 10%, transparent);
    color: var(--band-dark-fg);
    white-space: nowrap;
  }
  .closing-cta-row {
    justify-content: center;
  }
</style>
