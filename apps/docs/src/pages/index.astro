---
export const prerender = true;
import Base from '../layouts/Base.astro';
---

<Base
  title="Tinker"
  description="Learn math, physics, and computer science the way 3Blue1Brown wishes Brilliant worked. Rigorous, visual, and built for adults who actually want to understand."
>
  <section class="hero">
    <p class="eyebrow">In development · Coming 2026</p>
    <h1>Learn by building intuition, not memorizing steps.</h1>
    <p class="lede">
      Tinker is a new kind of learning app for math, physics, and computer
      science — interactive the whole way down, with spaced-repetition that
      actually tracks your understanding, and visualizations you can drag.
      For adults who want rigor and intuition in the same product.
    </p>

    <form class="waitlist" method="POST" action="#" data-waitlist>
      <label class="sr-only" for="waitlist-email">Email address</label>
      <input
        id="waitlist-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button type="submit">Get on the waitlist</button>
    </form>
    <p class="form-note">No spam. One email when there's something real to show.</p>
  </section>

  <section class="pitch" aria-labelledby="pitch-heading">
    <h2 id="pitch-heading">What we're building</h2>
    <ul class="pitch-grid">
      <li>
        <h3>Rigor <em>and</em> intuition</h3>
        <p>
          Brilliant builds intuition and stops short. Math Academy builds
          procedural fluency and feels dry. Tinker pairs draggable,
          3Blue1Brown-style visualizations with spaced-repetition on a
          hand-built knowledge graph — both in one product.
        </p>
      </li>
      <li>
        <h3>Knowledge graph you can trust</h3>
        <p>
          Every concept is a node with explicit prerequisites. Mastering an
          advanced topic trickles credit down the graph, so you never
          re-review what you've already proven you know.
        </p>
      </li>
      <li>
        <h3>Adult learners, not kids</h3>
        <p>
          No streaks guilt-tripping you. No cartoon characters. No walled
          garden. Built for self-directed learners — whether you're a dev
          brushing up linear algebra for ML or an engineer revisiting
          multivariable calc.
        </p>
      </li>
      <li>
        <h3>Works offline</h3>
        <p>
          Download a course, fly to Calgary, keep learning. Your progress
          syncs when you're back online. No subscription trap — pay once,
          learn forever is on the table.
        </p>
      </li>
    </ul>
  </section>

  <section class="status" aria-labelledby="status-heading">
    <h2 id="status-heading">Where this stands</h2>
    <p>
      Actively being built in the open. Source:
      <a href="https://github.com/SkipSupreme/svelte-mafs" rel="noopener">
        github.com/SkipSupreme/svelte-mafs
      </a>.
      Follow along on the waitlist and I'll ping you when the first wedge
      (Math for ML) is ready to dogfood.
    </p>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 3rem;
    max-width: 52rem;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    color: var(--site-accent);
    margin: 0 0 0.75rem;
    font-weight: 600;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }
  .lede {
    font-size: 1.18rem;
    line-height: 1.55;
    color: var(--site-fg-muted);
    max-width: 44rem;
    margin: 0 0 2rem;
  }

  .waitlist {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    max-width: 32rem;
    margin: 0 0 0.5rem;
  }
  .waitlist input[type="email"] {
    flex: 1 1 14rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-md);
    background: var(--site-surface);
    color: var(--site-fg);
    font: inherit;
  }
  .waitlist input[type="email"]:focus {
    outline: 2px solid var(--site-accent);
    outline-offset: 2px;
  }
  .waitlist button {
    padding: 0.75rem 1.1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--site-accent);
    background: var(--site-accent);
    color: var(--site-accent-fg);
    font: inherit;
    font-weight: 550;
    cursor: pointer;
    transition: transform 120ms ease;
  }
  .waitlist button:hover { transform: translateY(-1px); }
  .form-note {
    font-size: 0.82rem;
    color: var(--site-fg-muted);
    margin: 0.25rem 0 0;
  }

  .pitch, .status {
    padding: 2.75rem 0;
    border-top: 1px solid var(--site-border);
  }
  .pitch-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .pitch-grid li {
    padding: 1.25rem 1.25rem 1rem;
    border: 1px solid var(--site-border);
    border-radius: var(--radius-lg);
    background: var(--site-surface);
  }
  .pitch-grid h3 {
    font-family: var(--font-body);
    font-size: 1.02rem;
    margin: 0 0 0.4rem;
  }
  .pitch-grid em {
    font-style: italic;
    color: var(--site-accent);
    font-weight: 600;
  }
  .pitch-grid p {
    margin: 0;
    color: var(--site-fg-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .status p { color: var(--site-fg-muted); max-width: var(--max-prose); }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // Waitlist form stub — intercepts submit so the form doesn't 404 on a
  // non-existent endpoint. When a real provider (Beehiiv / Buttondown /
  // ConvertKit) is wired up, swap this for a real POST and remove the stub.
  const form = document.querySelector<HTMLFormElement>('form[data-waitlist]');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[type="email"]');
      if (!input?.value) return;
      const btn = form.querySelector<HTMLButtonElement>('button');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Noted — real signup coming soon';
      }
      console.log('[waitlist stub]', input.value);
    });
  }
</script>
