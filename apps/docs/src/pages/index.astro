---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Tinker from '../components/brand/Tinker.svelte';
import FloatingMath from '../components/brand/FloatingMath.svelte';
import EmbeddingPluck from '../components/demos/EmbeddingPluck.svelte';
import CourseAtlas from '../components/course/CourseAtlas.svelte';

// === Course Atlas data: arcs -> modules -> lessons, built at build time from
// the content collections so the homepage shows the entire course. ===
const courses = await getCollection('courses');
const course = courses.find((c) => c.id === 'ml-math') ?? courses[0];

const allModules = await getCollection('modules', (m) => !m.data.draft);
const allLessons = await getCollection('lessons', (l) => !l.data.draft);
const moduleById = new Map(allModules.map((m) => [m.id, m]));

type LessonEntry = (typeof allLessons)[number];
const lessonsByModule = new Map<string, LessonEntry[]>();
for (const l of allLessons) {
  const arr = lessonsByModule.get(l.data.module) ?? [];
  arr.push(l);
  lessonsByModule.set(l.data.module, arr);
}
for (const arr of lessonsByModule.values()) {
  arr.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}

// Arc accent tokens. sea -> teal -> red (keystone arc) -> orange -> pink.
// No purple; sun is reserved for XP per DESIGN.md.
const ARC_COLORS: Record<string, string> = {
  'arc-0-foundations': 'var(--ink-sea)',
  'arc-1-prereq-math': 'var(--ink-teal)',
  'arc-2-ml-foundations': 'var(--ink-red)',
  'arc-3-transformers': 'var(--ink-orange)',
  'arc-4-capstone': 'var(--ink-pink)',
};
const KEYSTONE = new Set(['m12-backpropagation']);

const atlasArcs = course.data.arcs.map((arc) => {
  const modules = arc.modules.flatMap((id) => {
    const m = moduleById.get(id);
    if (!m) return [];
    const lessons = (lessonsByModule.get(m.id) ?? []).map((l) => ({
      slug: l.id,
      title: l.data.title,
      order: l.data.order ?? 0,
      minutes: l.data.estimatedMinutes,
    }));
    const minutes = lessons.reduce((s, l) => s + l.minutes, 0);
    return [
      {
        id: m.id,
        anchor: m.id.split('-')[0],
        order: m.data.order,
        title: m.data.title,
        summary: m.data.summary,
        status: m.data.status,
        minutes,
        keystone: KEYSTONE.has(m.id),
        lessons,
      },
    ];
  });
  return {
    id: arc.id,
    title: arc.title,
    description: arc.description,
    color: ARC_COLORS[arc.id] ?? 'var(--ink-red)',
    modules,
    moduleCount: modules.length,
    lessonCount: modules.reduce((s, mm) => s + mm.lessons.length, 0),
    minutes: modules.reduce((s, mm) => s + mm.minutes, 0),
  };
});

const totals = {
  arcs: atlasArcs.length,
  modules: atlasArcs.reduce((s, a) => s + a.moduleCount, 0),
  lessons: atlasArcs.reduce((s, a) => s + a.lessonCount, 0),
  minutes: atlasArcs.reduce((s, a) => s + a.minutes, 0),
};
---

<Base
  title="Tinker"
  description="Play with ideas. Learn for real. Grow fast. Mini lessons, instant feedback, and joyful wins for curious kids, teens, and grown-ups."
  fullWidth
>
  <!-- Pre-hydration capture for hero events. The widget hydrates as a
       client:load island and may dispatch tinker:hero:* events before
       Tinker.svelte (client:visible) attaches. This inline capture-phase
       listener buffers events to window.__tinkerHeroBuffer so Tinker can
       drain them on mount. ARCH-3 / TENSION-3 from the plan-eng-review. -->
  <script is:inline>
    (function () {
      if (typeof window === 'undefined') return;
      window.__tinkerHeroBuffer = window.__tinkerHeroBuffer || [];
      var names = [
        'tinker:hero:focus',
        'tinker:hero:drag',
        'tinker:hero:threshold',
        'tinker:hero:success',
        'tinker:hero:idle',
      ];
      for (var i = 0; i < names.length; i++) {
        window.addEventListener(names[i], function (e) {
          if (window.__tinkerHeroBuffer && window.__tinkerHeroBuffer.length < 64) {
            window.__tinkerHeroBuffer.push(e);
          }
        }, true);
      }
    })();
  </script>

  <section class="hero band band-onyx">
    <FloatingMath client:visible />
    <div class="shell">
      <div class="hero-grid" data-hero-region>
        <div class="hero-mascot">
          <Tinker client:visible size="clamp(180px, 26vw, 280px)" />
        </div>
        <div class="hero-copy">
          <h1 class="hero-headline">
            <span class="line">Learn by playing</span>
            <span class="line">with the <span class="ink-red"><em>math.</em></span></span>
          </h1>
          <p class="lede">
            Drag a letter. Watch the constellation react. That's not a
            decoration. It's the core idea behind embeddings, the foundation
            of every modern AI model. Tinker teaches the math underneath
            machine learning by letting you touch it.
          </p>
          <div class="hero-widget">
            <EmbeddingPluck client:load hero={true} />
          </div>
          <div class="cta-row">
            <a class="btn primary" href="/signup">Sign up, it's free</a>
            <a class="btn secondary" href="/lessons">Explore the course</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three concrete proof-cards: real things you build in the course.
       Not generic feature pills, but actual module callbacks with the
       widget, the moment, the payoff. -->
  <section class="band band-white proof-band">
    <div class="shell">
      <p class="kicker kicker-red">What you'll actually build</p>
      <h2 class="proof-headline">
        Three moments. <em>Pick the one you want first.</em>
      </h2>

      <ol class="proof-grid">
        <li class="proof-card">
          <div class="proof-num"><span>12</span></div>
          <h3 class="proof-title">Backprop, from scratch</h3>
          <p class="proof-desc">
            Build micrograd one node at a time. Watch the gradient flow
            backward through a tanh, see how <code>loss.backward()</code>
            actually works. The keystone module of the course.
          </p>
          <a class="proof-link" href="#m12">
            Module 12 · Backpropagation →
          </a>
        </li>

        <li class="proof-card">
          <div class="proof-num"><span>15</span></div>
          <h3 class="proof-title">Attention, as a soft dictionary</h3>
          <p class="proof-desc">
            The thing you played with up top is an embedding, the
            foundation of attention. Drag a query vector, watch it pivot
            toward the right keys. Build the math behind the T in GPT.
          </p>
          <a class="proof-link" href="#m15">
            Module 15 · Attention →
          </a>
        </li>

        <li class="proof-card">
          <div class="proof-num"><span>18</span></div>
          <h3 class="proof-title">A real transformer, in your browser</h3>
          <p class="proof-desc">
            Capstone: 4 layers, 4 heads, ~200k params. Trains in ~5
            minutes on WebGPU. Generates Shakespeare-flavored nonsense.
            Yours to keep.
          </p>
          <a class="proof-link" href="#m18">
            Module 18 · Capstone →
          </a>
        </li>
      </ol>
    </div>
  </section>

  <!-- The whole course, arc by arc: every module and every lesson rendered as
       an interactive climb. Replaces the old four-arc teaser. Each module node
       expands to reveal its lessons; signed-in learners see progress light up. -->
  <section class="band band-cream atlas-band">
    <div class="atlas-intro">
      <p class="kicker kicker-red">The whole course</p>
      <h2 class="atlas-headline">
        Every lesson. <em>One continuous climb.</em>
      </h2>
      <p class="atlas-lede">
        From <code class="atlas-code">f(x) = x²</code> to a transformer you train
        yourself. Open any module to see its lessons. Sign in and the map lights
        up with what you've finished.
      </p>
    </div>
    <CourseAtlas client:visible arcs={atlasArcs} totals={totals} />
    <div class="atlas-cta">
      <a class="btn primary" href="/lessons">Open the full course →</a>
    </div>
  </section>

  <!-- Closing CTA: dark hero band, premium feel. The work is the pitch. -->
  <section class="band band-onyx closing-band">
    <div class="shell tall">
      <h2 class="closing-headline">
        There's a math underneath every model.
        <em class="closing-em">You can touch it.</em>
      </h2>
      <p class="closing-sub">
        Ninety-two lessons, nineteen modules, free in your browser. From
        <code class="closing-code">f(x) = x²</code> to a transformer you
        train yourself on the GPU in your laptop.
      </p>
      <div class="cta-row closing-cta-row">
        <a class="btn primary" href="/signup">Sign up, it's free</a>
        <a class="btn secondary" href="/lessons">Explore the course</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .band {
    width: 100%;
    padding: clamp(3rem, 7vw, 5.5rem) 1.25rem;
    position: relative;
    overflow: hidden;
  }
  .band-cream    { background: var(--band-cream); }
  .band-butter   { background: var(--band-butter); }
  .band-white    { background: var(--band-white); }
  .band-onyx {
    /* Fallback for engines without color-mix() (iOS Safari < 16.2): the whole
       multi-layer background shorthand below is invalid there and gets dropped,
       so declare the solid band first to keep the section from rendering with
       no background. Modern engines apply the radial-accent layers. */
    background: var(--band-onyx);
    background:
      radial-gradient(circle at 25% 30%, color-mix(in srgb, var(--ink-red) 22%, transparent), transparent 55%),
      radial-gradient(circle at 80% 80%, color-mix(in srgb, var(--ink-coral) 14%, transparent), transparent 55%),
      var(--band-onyx);
    color: var(--band-dark-fg);
  }
  .band-quiet { padding: clamp(4rem, 9vw, 7rem) 1.25rem; }

  .shell {
    max-width: var(--max-hero);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .shell.tall { text-align: center; padding: 1rem 0 2rem; }

  /* === Hero ===
     Padding kept tight so the CTAs sit above the fold on a 1280×900 viewport.
     Previously top:4rem / bottom:5.5rem made the hero 965px and pushed the
     CTAs below 900. */
  .hero { padding: 1rem 1.25rem 1.5rem; }
  .hero-grid {
    /* Apple on the left, copy on the right. align-items:start anchors the
       mascot at the top of the headline instead of floating in the middle
       of a 700px-tall copy column (which is what happened with center). */
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(0, 1.25fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  /* Eyebrow chip above the headline: uppercase kicker per DESIGN.md
     (0.75rem, 0.14em letter-spacing). Without these styles it was
     rendering as plain 16px Inter body text. */
  .eyebrow {
    margin: 0 0 0.6rem;
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--ink-red);
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    /* Mascot is first in source order, so it naturally stacks above copy
       on mobile, so no `order` override is needed. */
  }
  /* On phones the mascot column was eating the whole above-fold viewport
     before the headline showed. Cap the mascot at a comfortable thumbnail
     size. Do NOT clip here: the mascot's .tinker-glow is an inset:-10% +
     blur(18px) halo that must feather past the 200px box. overflow:hidden
     used to crop it to a hard rectangular edge ("glow ends abruptly" on iOS
     Safari). The parent .band already has overflow:hidden, so the glow stays
     within the section and never triggers horizontal page scroll. */
  @media (max-width: 640px) {
    .hero { padding: 1.25rem 1rem 1.5rem; }
    .hero-mascot {
      min-height: 0;
      max-width: 200px;
      margin: 0 auto;
    }
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 6.5vw, 5rem);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0 0 1.4rem;
    text-wrap: balance;
  }
  .hero-headline .line {
    display: block;
  }
  .hero-headline em {
    font-style: italic;
    font-weight: 700;
    /* Per-verb color set via .ink-red/coral/sun spans. */
  }
  .ink-red    { color: var(--ink-red); }
  .ink-coral  { color: var(--ink-coral); }
  .ink-sun    { color: var(--ink-sun); }
  .ink-sun-italic {
    color: var(--ink-sun);
    font-style: italic;
  }
  .nowrap { white-space: nowrap; }

  .lede {
    font-size: clamp(1.05rem, 1.55vw, 1.25rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--band-dark-fg) 85%, transparent);
    max-width: 36ch;
    margin: 0 0 1.25rem;
  }
  .lede.dark {
    color: var(--band-dark-muted);
    margin-left: auto;
    margin-right: auto;
    max-width: 38ch;
  }

  /* CTA pair */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0 0 1rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.6rem;
    border-radius: var(--radius-pill);
    font: inherit;
    font-weight: 700;
    font-size: 1.02rem;
    text-decoration: none;
    line-height: 1;
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: transform 140ms ease, background-color 140ms ease, box-shadow 140ms ease;
  }
  .btn.primary {
    background: var(--cta);
    color: var(--cta-fg);
    border-color: var(--cta);
    box-shadow: 0 10px 22px -8px color-mix(in srgb, var(--cta) 70%, transparent);
  }
  .btn.primary:hover {
    background: var(--cta-hover);
    border-color: var(--cta-hover);
    transform: translateY(-1px);
    box-shadow: 0 14px 26px -8px color-mix(in srgb, var(--cta) 80%, transparent);
  }
  .btn.primary:active { transform: translateY(0); }
  .btn.secondary {
    /* Mixes against the current band-dark-fg so the ghost CTA reads
       correctly on either theme: dark border on light hero, light border
       on dark hero. */
    background: transparent;
    color: var(--band-dark-fg);
    border-color: color-mix(in srgb, var(--band-dark-fg) 30%, transparent);
  }
  .btn.secondary:hover {
    background: color-mix(in srgb, var(--band-dark-fg) 6%, transparent);
    border-color: color-mix(in srgb, var(--band-dark-fg) 55%, transparent);
  }

  .reassurance {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    font-family: var(--font-game);
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--band-dark-fg) 65%, transparent);
  }
  .reassurance li { display: inline-flex; align-items: center; gap: 0.4rem; }
  .reassurance li span { opacity: 0.55; }
  .reassurance li:first-child span { display: none; }

  /* === Hero mascot ===
     The interactive <Tinker /> component handles its own glow, idle bob,
     hover-tilt, click bounce, and reduced-motion fallback. We just give
     it a positioned container so the XP floater can anchor to it. */
  .hero-mascot {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    /* Center the mascot against the full copy column instead of pinning it
       to the top. With align-items:start on the grid the apple floated up by
       the eyebrow with a large void beneath it; centering balances the row. */
    align-self: center;
  }

  /* === Hero widget container ===
     EmbeddingPluck in hero mode lives between the lede and the CTA row.
     The widget itself handles its border, shadow, and stage styling.
     Capped narrower than the copy column so the CTAs stay above the fold
     on a 1280×900 viewport. */
  .hero-widget {
    margin: 0.4rem 0 1rem;
    width: 100%;
    max-width: 460px;
  }
  @media (max-width: 900px) {
    .hero-widget { margin: 0.6rem auto 1rem; max-width: 100%; }
  }

  /* Floating math symbols above the apple. Tinker is math-as-play, so the
     ambient decoration is the alphabet of math itself. Confetti palette
     (teal/pink/orange) per DESIGN.md. */
  .confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .sym {
    position: absolute;
    font-family: var(--font-display), serif;
    font-style: italic;
    font-weight: 600;
    line-height: 1;
    user-select: none;
    text-shadow: 0 2px 8px color-mix(in srgb, currentColor 30%, transparent);
  }
  .sym-pi      { top: 10%; right: 28%; color: var(--ink-teal);   font-size: 2.4rem; transform: rotate(-12deg); animation: sym-drift 7s ease-in-out infinite; }
  .sym-int     { top: 4%;  right: 16%; color: var(--ink-pink);   font-size: 2.8rem; transform: rotate(8deg);   animation: sym-drift 8s ease-in-out infinite reverse; }
  .sym-partial { top: 16%; right: 8%;  color: var(--ink-orange); font-size: 2.2rem; transform: rotate(-4deg);  animation: sym-drift 6.5s ease-in-out infinite; }
  .sym-infty   { top: 30%; right: 4%;  color: var(--ink-teal);   font-size: 2rem;   transform: rotate(14deg);  animation: sym-drift 9s ease-in-out infinite reverse; }
  .sym-delta   { top: 4%;  right: 38%; color: var(--ink-orange); font-size: 1.9rem; transform: rotate(-18deg); animation: sym-drift 7.5s ease-in-out infinite; }
  .sym-sigma   { top: 22%; right: 38%; color: var(--ink-pink);   font-size: 2.1rem; transform: rotate(6deg);   animation: sym-drift 8.5s ease-in-out infinite reverse; }

  @keyframes sym-drift {
    0%, 100% { translate: 0 0; }
    50%      { translate: -4px -8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .sym { animation: none; }
  }

  /* === XP floater === */
  .xp-floater {
    position: absolute;
    bottom: 8%;
    right: 4%;
    z-index: 2;
    background: color-mix(in srgb, var(--ink-sun) 18%, var(--band-onyx));
    color: var(--ink-sun);
    border: 1.5px solid color-mix(in srgb, var(--ink-sun) 45%, transparent);
    border-radius: var(--radius-pill);
    padding: 0.55rem 1rem;
    font-family: var(--font-game);
    font-weight: 700;
    font-size: 0.92rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    box-shadow: 0 14px 24px -10px color-mix(in srgb, var(--ink-sun) 55%, transparent);
    animation: xp-pop 4s ease-in-out infinite;
  }
  .xp-amount { font-variant-numeric: tabular-nums; letter-spacing: 0.02em; }
  .xp-msg {
    color: color-mix(in srgb, var(--ink-sun) 80%, var(--on-color-fg));
    font-weight: 600;
    font-size: 0.85rem;
  }
  .xp-confetti {
    position: absolute;
    inset: -16px -10px -16px -10px;
    pointer-events: none;
  }
  .xp-confetti .bit {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    opacity: 0;
    animation: xp-burst 4s ease-in-out infinite;
  }
  .xp-confetti .b1 { top: -4px;  left: 10%; background: var(--ink-teal);   animation-delay: 0s; }
  .xp-confetti .b2 { top: -8px;  left: 35%; background: var(--ink-pink);   animation-delay: 0.1s; }
  .xp-confetti .b3 { top: -2px;  left: 60%; background: var(--ink-orange); animation-delay: 0.2s; }
  .xp-confetti .b4 { bottom: -4px; left: 20%; background: var(--ink-red); animation-delay: 0.3s; }
  .xp-confetti .b5 { bottom: -6px; left: 55%; background: var(--ink-teal);   animation-delay: 0.15s; }
  .xp-confetti .b6 { bottom: -2px; left: 80%; background: var(--ink-pink);   animation-delay: 0.25s; }

  @keyframes xp-pop {
    0%, 70%, 100% { transform: scale(1); }
    74%           { transform: scale(1.06); }
    78%           { transform: scale(1); }
  }
  @keyframes xp-burst {
    0%, 65%, 100% { opacity: 0; transform: translate(0, 0); }
    70%           { opacity: 1; }
    85%           { opacity: 0.9; transform: translate(var(--bx, 8px), var(--by, -10px)); }
    95%           { opacity: 0; transform: translate(calc(var(--bx, 8px) * 1.5), calc(var(--by, -10px) * 1.5)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .xp-floater { animation: none; }
    .xp-confetti .bit { display: none; }
  }

  /* Mobile: shrink XP floater so it doesn't crowd the mascot. */
  @media (max-width: 600px) {
    .xp-floater {
      bottom: 6%;
      right: 6%;
      font-size: 0.82rem;
      padding: 0.45rem 0.85rem;
    }
    .xp-msg { display: none; }
  }

  /* === Lesson tiles === */
  .tiles-band { padding: clamp(3rem, 6vw, 5rem) 1.25rem; }
  .kicker {
    font-family: var(--font-game);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    font-weight: 700;
    margin: 0 0 0.85rem;
  }
  .kicker-red { color: var(--ink-red); }
  .kicker-sea    { color: var(--ink-sea); }

  .tiles-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.7rem, 3.4vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.75rem;
    text-wrap: balance;
  }
  .tiles-headline em {
    font-style: italic;
    color: var(--ink-red);
    font-weight: 700;
  }

  .tiles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  .tiles-single {
    grid-template-columns: minmax(280px, 520px);
    justify-content: center;
  }
  .tiles-footnote {
    margin: 1.5rem auto 0;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    color: var(--site-fg-muted);
    max-width: 36ch;
  }

  /* === Proof band: three things you'll actually build. === */
  .proof-band { padding: clamp(3rem, 6vw, 5rem) 1.25rem; }
  .proof-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 2rem;
    /* Constrain so the headline wraps to two balanced lines instead of
       running edge-to-edge across the full band on wide viewports. */
    max-width: 20ch;
    text-wrap: balance;
  }
  .proof-headline em { font-style: italic; color: var(--ink-coral); font-weight: 700; }
  .proof-grid {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
