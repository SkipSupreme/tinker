{
  "name": "svelte-mafs-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:css": "stylelint \"apps/docs/src/**/*.{css,svelte,astro}\" --allow-empty-input",
    "test:e2e": "playwright test",
    "test:perf": "RUN_PERF=1 playwright test apps/docs/tests/e2e/perf.spec.ts --project=docs-chromium"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@playwright/test": "^1.60.0",
    "lighthouse": "^13.1.0",
    "playwright-lighthouse": "^4",
    "postcss-html": "^1.8.1",
    "stylelint": "^16",
    "stylelint-config-standard": "^36",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.11"
  },
  "pnpm": {
    "overrides": {
      "svelte": "^5.55.9",
      "devalue": "^5.8.1",
      "kysely": "~0.28.17",
      "ws": "^8.20.1",
      "fast-uri": "^3.1.2",
      "esbuild": "^0.25.0",
      "vitest": "^3.2.6"
    }
  }
}
